PORT=3000
CORS_ORIGIN=*
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/opc?schema=public
STORAGE_DIR=./storage
JWT_SECRET=opc-local-dev-secret
ACCESS_TOKEN_TTL=2h
REFRESH_TOKEN_TTL=30d

# Environment classification
# IS_RELEASE=true forces release-like guards even in test/CI.
NODE_ENV=development
APP_ENV=local
IS_RELEASE=false

# Dev-only switches
DEV_MOCK_WECHAT_LOGIN=false
ALLOW_MOCK_WECHAT_LOGIN=false
ALLOW_DEV_FRESH_USER_LOGIN=false
DEV_FRESH_LOGIN_SECRET=
DEV_MOCK_DIFY=false

# WeChat Mini Program credentials (required when release-like)
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
# Optional aliases (use either pair, not both)
# WECHAT_APPID=wx_your_app_id
# WECHAT_SECRET=your_wechat_app_secret

# Aliyun SMS verification code
# In local/dev, SMS_ENABLED=false also uses dry-run and returns devCode for verification.
SMS_ENABLED=false
# Local-only: returns devCode and skips provider send. Must stay false in release-like envs.
ALIYUN_SMS_DRY_RUN=false
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_TEMPLATE_PARAM_NAME=code
SMS_CODE_DIGITS=6
SMS_CODE_TTL_SECONDS=300
SMS_CODE_COOLDOWN_SECONDS=60
SMS_CODE_MAX_PER_PHONE_PER_HOUR=5
SMS_CODE_MAX_VERIFY_ATTEMPTS=5
SMS_CODE_HASH_SECRET=

# Dify API
# Dify Cloud: https://api.dify.ai/v1
# Self-hosted example: http://localhost:8080/v1
DIFY_ENABLED=false
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_API_KEY_ASSET_FIRST=
DIFY_API_KEY_ASSET_RESUME=
DIFY_API_KEY_ASSET_REVIEW=
DIFY_API_KEY_ASSET_REPORT=
DIFY_API_KEY_ONBOARDING_FALLBACK=
DIFY_API_KEY_INFO_COLLECTION=
DIFY_API_KEY_BUSINESS_HEALTH=
DIFY_API_KEY_OPPORTUNITY_DIRECTIONS=
DIFY_API_KEY_OPPORTUNITY_DEEP_DIVE=
DIFY_API_KEY_PROJECT_FOLLOWUP=
DIFY_API_KEY_FOLLOWUP_PLANNER=
DIFY_REQUEST_TIMEOUT_MS=120000
DIFY_SNAPSHOT_TTL_MINUTES=15

# L1 memory extraction
MEMORY_EXTRACTION_ENABLED=true
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MEMORY_EXTRACTOR_MODEL=glm-4-flash
MEMORY_EXTRACTOR_TIMEOUT_MS=15000
MEMORY_EXTRACTOR_MAX_TOKENS=500

# Policy / park opportunity search
POLICY_SEARCH_ENABLED=false
POLICY_SEARCH_PROVIDER=mock
POLICY_SEARCH_API_KEY=
POLICY_SEARCH_TTL_MINUTES=360
POLICY_SEARCH_TIMEOUT_MS=10000
POLICY_SEARCH_ALLOWED_DOMAINS=gov.cn,zwfw.gov.cn,tax.gov.cn

# Session window (Layer A)
SESSION_WINDOW_TTL_MINUTES=60
SESSION_WINDOW_MAX_MESSAGES=20

# Chatflow summarizer (Layer C)
CHATFLOW_SUMMARY_ENABLED=true
CHATFLOW_SUMMARIZER_MODEL=glm-4-air
CHATFLOW_SUMMARIZER_MAX_TOKENS=400
CHATFLOW_SUMMARIZER_TIMEOUT_MS=20000
CHATFLOW_SUMMARY_MIN_MESSAGES=4
CHATFLOW_SUMMARY_INJECT_LIMIT=3
CHATFLOW_SUMMARY_DEDUP_WINDOW_MS=300000

# L3 profile recompute
USER_PROFILE_RECOMPUTE_ENABLED=true
PROFILE_LLM_ENRICH_ENABLED=true
PROFILE_LLM_MODEL=glm-4-flash
PROFILE_LLM_TIMEOUT_MS=12000
PROFILE_LLM_MAX_TOKENS=500
