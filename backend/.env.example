PORT=3000
CORS_ORIGIN=*
PUBLIC_BASE_URL=http://localhost:3000
JWT_SECRET=opc-local-dev-secret
ACCESS_TOKEN_TTL=2h
REFRESH_TOKEN_TTL=30d
# 本地没有微信正式凭证时可以先保留 true，线上建议关闭
ALLOW_MOCK_WECHAT_LOGIN=true
# 从微信公众平台 -> 开发管理 -> 开发设置获取
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Dify API
# Dify Cloud: https://api.dify.ai/v1
# Self-hosted example: http://localhost:8080/v1
DIFY_ENABLED=false
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_REQUEST_TIMEOUT_MS=120000
