PORT=3000
CORS_ORIGIN=*
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://opc:opc@127.0.0.1:5432/opc?schema=public
STORAGE_DIR=./storage
JWT_SECRET=opc-local-dev-secret
ACCESS_TOKEN_TTL=2h
REFRESH_TOKEN_TTL=30d
# 仅开发模式使用的显式降级开关
DEV_MOCK_WECHAT_LOGIN=false
DEV_MOCK_DIFY=false
# 兼容旧配置，建议逐步迁移到 DEV_MOCK_WECHAT_LOGIN
ALLOW_MOCK_WECHAT_LOGIN=false
# 从微信公众平台 -> 开发管理 -> 开发设置获取
WECHAT_APP_ID=wx11a47e0195bc4c54
WECHAT_APP_SECRET=68c65e1c78ced17f14d48acb32af01da
# Optional aliases (use either pair, not both)
# WECHAT_APPID=wx11a47e0195bc4c54
# WECHAT_SECRET=68c65e1c78ced17f14d48acb32af01da

# Dify API
# Dify Cloud: https://api.dify.ai/v1
# Self-hosted example: http://localhost:8080/v1
DIFY_ENABLED=false
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
