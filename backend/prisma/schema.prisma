generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ArtifactType {
  ASSET_RADAR
  OPPORTUNITY_SCORES
  SELECTED_DIRECTION
  VALIDATION_PLAN
  BUSINESS_HEALTH
  PRODUCT_STRUCTURE
  PRICING_CARD
  OUTREACH_SCRIPTS
  REVENUE_STRUCTURE
  PROFIT_FIRST_CONFIG
  PARK_MATCH
  ACTION_PLAN_48H
  AUTOMATION_WORKFLOW
  PROFILE_SNAPSHOT
  WEEKLY_REPORT
  MONTHLY_REPORT
  SOCIAL_PROOF
  MILESTONE
  SHARE_PREVIEW
}

enum RouterAgentKey {
  master
  asset
  execution
  mindset
  steward
}

enum RouterMode {
  guided
  locked
  free
}

enum RouterSessionStatus {
  in_progress
  completed
  abandoned
}

// L1 —— 原子化用户事实分类（见 abundant-forging-papert.md §3.4）
enum UserFactCategory {
  skill
  resource
  cognition
  relationship
  experience
  personality
  preference
  pain_point
  goal
  business
  behavior
}

// L1 —— 雷达图维度，聚合画像时按此维度分组
enum UserFactDimension {
  capability
  resource
  cognition
  relationship
}

// L1 —— 事实来源，用于区分实时抽取 / 批处理 / 用户显式声明 / 旧数据迁移
enum UserFactSource {
  llm_realtime
  llm_batch
  user_explicit
  system_infer
  legacy
}

enum BehaviorEventType {
  app_open
  message_sent
  task_completed
  task_skipped
  agent_switched
  artifact_viewed
  knowledge_browsed
  project_created
}

enum SubscriptionTokenStatus {
  available
  used
  expired
}

enum DailyTaskStatus {
  pending
  completed
  skipped
}

enum SnapshotKind {
  PROFILE
  ASSET_INVENTORY
  WEEKLY_REPORT
  MONTHLY_REPORT
  SOCIAL_PROOF
  MILESTONE
  SHARE_PREVIEW
}

// Phase 1.4 —— L0 会话窗口消息角色（与 MessageRole 分离，因为窗口里也要区分 agent/user/system）
enum SessionContextRole {
  user
  assistant
  system
}

// Phase 1.5 —— L2 记忆条目类型。当前只落 session_summary，另两个预留给未来的"显式记笔记"和"顿悟洞察"。
enum ChatflowSummaryType {
  session_summary
  persistent
  insight
}

// Phase 1.5 —— 会话摘要触发来源，便于事后回溯是什么事件催生了这条摘要
enum ChatflowSummaryTrigger {
  agent_switch
  session_completed
  manual
  cron_daily
  cron_weekly
}

// Phase 1.6 —— L3 聚合画像类型
enum UserProfileType {
  asset_radar
  personality
  ikigai
  business_status
}

enum UserRole {
  user
  admin
}

model User {
  id               String            @id @db.VarChar(64)
  role             UserRole          @default(user)
  name             String            @db.VarChar(120)
  nickname         String            @db.VarChar(120)
  initial          String            @db.VarChar(8)
  stage            String?           @db.VarChar(120)
  streakDays       Int               @default(0)
  subtitle         String?           @db.VarChar(255)
  avatarUrl        String?           @db.VarChar(2048)
  loggedIn         Boolean           @default(false)
  loginMode        String?           @db.VarChar(64)
  openId           String?           @db.VarChar(128)
  unionId          String?           @db.VarChar(128)
  gender           Int?
  country          String?           @db.VarChar(80)
  province         String?           @db.VarChar(80)
  city             String?           @db.VarChar(80)
  language         String?           @db.VarChar(32)
  wechatOpenid     String?           @unique @db.VarChar(128)
  onboardingCompleted Boolean        @default(false)
  entryPath        String?           @db.VarChar(64)
  isActiveOpc      Boolean           @default(false)
  subscriptionCount Int              @default(0)
  // Phase 2 —— 业务流转状态 flag
  lastIncompleteFlow       String?   @db.VarChar(64)
  lastIncompleteStep       String?   @db.VarChar(64)
  hasAssetRadar            Boolean   @default(false)
  hasOpportunityScores     Boolean   @default(false)
  hasSelectedDirection     Boolean   @default(false)
  hasBusinessHealth        Boolean   @default(false)
  hasProductStructure      Boolean   @default(false)
  hasPricingCard           Boolean   @default(false)
  activeChatflowId         String?   @db.VarChar(64)
  activeDifyConversationId String?   @db.VarChar(128)
  lastActiveAt     DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  wechatIdentities WechatIdentity[]
  sessions         Session[]
  projects         Project[]
  conversations    Conversation[]
  messages         Message[]
  dailyTasks       DailyTask[]
  taskFeedback     TaskFeedback[]
  growthSnapshots  GrowthSnapshot[]
  reportSnapshots  ReportSnapshot[]
  shareRecords     ShareRecord[]
  artifacts        Artifact[]
  conversationStates ConversationState[]
  userFacts        UserFact[]
  sessionContextEntries SessionContextEntry[]
  chatflowSummaries ChatflowSummary[]
  userProfiles     UserProfile[]
  behaviorLogs     BehaviorLog[]
  subscriptionTokens SubscriptionToken[]

  @@index([deletedAt])
}

model WechatIdentity {
  id         String   @id @default(cuid())
  userId     String   @db.VarChar(64)
  openId     String?  @unique @db.VarChar(128)
  unionId    String?  @unique @db.VarChar(128)
  sessionKey String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id                    String   @id @db.VarChar(64)
  userId                String   @db.VarChar(64)
  refreshToken          String   @unique @db.Text
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  revokedAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
}

model Project {
  id                  String            @id @db.VarChar(128)
  userId              String            @db.VarChar(64)
  name                String            @db.VarChar(120)
  phase               String?           @db.VarChar(80)
  status              String?           @db.VarChar(80)
  statusTone          String?           @db.VarChar(80)
  color               String?           @db.VarChar(32)
  agentLabel          String?           @db.VarChar(80)
  conversation        Json?
  conversationReplies Json?
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifacts           ProjectArtifact[]

  @@index([userId, deletedAt])
}

model ProjectArtifact {
  id        String   @id @db.VarChar(128)
  projectId String   @db.VarChar(128)
  type      String   @db.VarChar(64)
  title     String   @db.VarChar(200)
  data      Json?
  meta      String?  @db.VarChar(255)
  summary   String?  @db.Text
  cta       Json?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, deletedAt])
}

model Conversation {
  id              String               @id @db.VarChar(128)
  userId          String               @db.VarChar(64)
  sceneKey        String?              @db.VarChar(128)
  label           String               @db.VarChar(255)
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  lastMessageAt   DateTime?
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  streamEvents    StreamEvent[]
  providerBinding ProviderConversation?

  @@index([userId, deletedAt, updatedAt])
}

model ProviderConversation {
  id                     String       @id @default(cuid())
  conversationId         String       @unique @db.VarChar(128)
  providerConversationId String       @db.VarChar(255)
  lastProviderMessageId  String?      @db.VarChar(255)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  conversation           Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Message {
  id                String       @id @db.VarChar(128)
  conversationId    String       @db.VarChar(128)
  userId            String       @db.VarChar(64)
  role              MessageRole
  type              String       @db.VarChar(32)
  text              String       @db.Text
  agentKey          String?      @db.VarChar(32)
  providerMessageId String?      @db.VarChar(255)
  raw               Json?
  createdAt         DateTime     @default(now())
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
}

model StreamEvent {
  id             String       @id @default(cuid())
  streamId       String       @db.VarChar(128)
  conversationId String       @db.VarChar(128)
  eventIndex     Int
  type           String       @db.VarChar(32)
  payload        Json
  deliveredAt    DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([streamId, eventIndex])
  @@index([streamId, deliveredAt, eventIndex])
}

model DailyTask {
  id          String   @id @db.VarChar(128)
  userId      String   @db.VarChar(64)
  projectId   String?  @db.VarChar(128)
  label       String   @db.VarChar(120)
  content     String?  @db.Text
  tag         String?  @db.VarChar(120)
  agentKey    String?  @db.VarChar(32)
  status      DailyTaskStatus @default(pending)
  dueDate     DateTime?
  done        Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, done])
}

model TaskFeedback {
  id        String   @id @default(cuid())
  userId    String   @db.VarChar(64)
  taskId    String?  @db.VarChar(128)
  taskLabel String?  @db.VarChar(120)
  summary   String?  @db.Text
  advice    String?  @db.Text
  payload   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model GrowthSnapshot {
  id               String   @id @default(cuid())
  userId           String   @unique @db.VarChar(64)
  overview         Json
  milestones       Json
  currentMilestone Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReportSnapshot {
  id        String       @id @default(cuid())
  userId    String       @db.VarChar(64)
  kind      SnapshotKind
  data      Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@index([userId, kind])
}

model ShareRecord {
  id         String   @id @db.VarChar(128)
  userId     String   @db.VarChar(64)
  resultId   String?  @db.VarChar(128)
  title      String?  @db.VarChar(200)
  caption    String?  @db.Text
  hashtags   Json?
  posterPath String?  @db.Text
  imageUrl   String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Artifact {
  id        String       @id @default(cuid())
  userId    String       @db.VarChar(64)
  type      ArtifactType
  data      Json
  version   Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, version])
  @@index([userId, type, updatedAt])
}

model ConversationState {
  id                 String              @id @default(cuid()) @db.VarChar(128)
  userId             String              @db.VarChar(64)
  chatflowId         String              @db.VarChar(128)
  agentKey           RouterAgentKey
  mode               RouterMode
  status             RouterSessionStatus
  currentStep        String?             @db.VarChar(120)
  pendingQuestion    String?             @db.Text
  clarifyCount       Int                 @default(0)
  parkingLot         Json?
  difyConversationId String?             @db.VarChar(255)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
}

// ============================================
// L1 —— 原子化用户事实（Level 1 加工层）
// 每轮对话异步抽取，累积形成"神经元"级别的结构化用户画像。
// 同一 factKey 的更新走 version+1，并把旧版 isActive=false 保留。
// ============================================
model UserFact {
  id                BigInt              @id @default(autoincrement())
  userId            String              @db.VarChar(64)
  category          UserFactCategory
  dimension         UserFactDimension?
  factKey           String              @db.VarChar(128)
  factValue         String              @db.Text
  confidence        Float               @default(1)
  sourceMessageId   String?             @db.VarChar(128)
  sourceChatflowId  String?             @db.VarChar(128)
  extractedBy       UserFactSource      @default(llm_realtime)
  isActive          Boolean             @default(true)
  version           Int                 @default(1)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, factKey, version])
  @@index([userId, category, isActive, updatedAt])
  @@index([userId, dimension, isActive])
}

// ============================================
// Phase 1.4 —— L0 60 分钟滑动会话窗口（Layer A 注入源）
// 对齐 abundant-forging-papert.md §3.2 呼吸节奏三 + §3.4 session_context 表
// 每条用户消息和 agent 响应都会写入一条，expiresAt = createdAt + 60min
// 读取时按 expiresAt > now() 过滤，定期由后台任务或懒清理淘汰过期行
// ============================================
model SessionContextEntry {
  id             BigInt             @id @default(autoincrement())
  userId         String             @db.VarChar(64)
  role           SessionContextRole
  content        String             @db.Text
  agentKey       String?            @db.VarChar(32)
  chatflowId     String?            @db.VarChar(128)
  sourceMessageId String?           @db.VarChar(128)
  expiresAt      DateTime
  createdAt      DateTime           @default(now())
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt, createdAt])
}

// ============================================
// Phase 1.5 —— L2 会话摘要（Layer C 注入源）
// 对齐 abundant-forging-papert.md §3.4 memory_entries + §4.3 会话摘要器
// chatflow 完成 / agent 切换时由 ChatflowSummaryService fire-and-forget 写入
// ============================================
model ChatflowSummary {
  id             BigInt                 @id @default(autoincrement())
  userId         String                 @db.VarChar(64)
  memoryType     ChatflowSummaryType    @default(session_summary)
  trigger        ChatflowSummaryTrigger
  content        String                 @db.Text
  relevanceTags  String[]               @default([])
  sourceAgentKey String?                @db.VarChar(32)
  sourceChatflowId String?              @db.VarChar(128)
  sourceRangeStart DateTime?
  sourceRangeEnd   DateTime?
  createdAt      DateTime               @default(now())
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, memoryType, createdAt])
  @@index([userId, sourceAgentKey, createdAt])
}

// ============================================
// Phase 1.6 —— L3 聚合画像（雷达图等）
// 对齐 abundant-forging-papert.md §3.4 user_profiles
// 每次写入都把旧版 isCurrent=false，保留 version 方便回溯
// ============================================
model UserProfile {
  id              BigInt          @id @default(autoincrement())
  userId          String          @db.VarChar(64)
  profileType     UserProfileType
  profileData     Json
  sourceFactCount Int             @default(0)
  isCurrent       Boolean         @default(true)
  version         Int             @default(1)
  generatedAt     DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, profileType, version])
  @@index([userId, profileType, isCurrent])
}

model BehaviorLog {
  id        String            @id @default(cuid())
  userId    String            @db.VarChar(64)
  eventType BehaviorEventType
  eventData Json?
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType, createdAt])
}

model SubscriptionToken {
  id          String                  @id @default(cuid())
  userId      String                  @db.VarChar(64)
  templateId  String                  @db.VarChar(128)
  status      SubscriptionTokenStatus @default(available)
  triggeredAt DateTime?
  usedAt      DateTime?
  createdAt   DateTime                @default(now())
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

// Phase A4 —— Dify 调用用量追踪
// 每次 Dify chat/stream/workflow 调用落一行，方便后续按用户/按 workflow 聚合成本，
// 驱动 B3 看板和 A3 配额检查。
// 为了不阻塞热路径，写入是 fire-and-forget，失败只记日志。
model DifyUsageLog {
  id             String   @id @default(cuid())
  userId         String?  @db.VarChar(64)
  workflowKey    String   @db.VarChar(64)
  apiKeyTag      String   @db.VarChar(64)
  conversationId String?  @db.VarChar(128)
  messageId      String?  @db.VarChar(128)
  status         String   @db.VarChar(24)
  promptTokens   Int      @default(0)
  completionTokens Int    @default(0)
  totalTokens    Int      @default(0)
  latencyMs      Int      @default(0)
  costCents      Int      @default(0)
  errorCode      String?  @db.VarChar(64)
  errorMessage   String?  @db.VarChar(512)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([workflowKey, createdAt])
  @@index([status, createdAt])
}

/// Phase B4 —— /ready 写入探针计数表。id 固定一行（'ready'），每次深度检查 UPDATE。
/// 用途只有两个：确认 DB 可写、给运维一个"上次探活时间"指针；不承载任何业务语义。
model HealthProbe {
  id         String   @id @db.VarChar(32)
  probedAt   DateTime @default(now())
  probeCount Int      @default(0)
}

/// Phase B1 —— 错误上报持久化（前端 + 后端）。
/// source=client 来自小程序 onError；source=server 来自 GlobalHttpExceptionFilter。
/// Sentry DSN 配置后，ErrorReportService 会在写表之外异步转发一份。
model ErrorLog {
  id           String   @id @default(cuid())
  source       String   @db.VarChar(16)
  level        String   @db.VarChar(16)
  userId       String?  @db.VarChar(64)
  requestId    String?  @db.VarChar(128)
  route        String?  @db.VarChar(255)
  message      String   @db.VarChar(1024)
  stack        String?  @db.Text
  context      Json?
  userAgent    String?  @db.VarChar(512)
  appVersion   String?  @db.VarChar(64)
  createdAt    DateTime @default(now())

  @@index([source, createdAt])
  @@index([userId, createdAt])
  @@index([level, createdAt])
}
