.scene-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f3f3f4;
}

.scene-body {
  flex: 1;
  min-height: 0;
}

.scene-scroll {
  height: 100%;
}

.message-stream {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 20rpx 24rpx 16rpx;
}

.scene-footer {
  padding: 10rpx 18rpx calc(env(safe-area-inset-bottom) + 14rpx);
  background: linear-gradient(180deg, rgba(243, 243, 244, 0), rgba(243, 243, 244, 0.96) 46%, rgba(243, 243, 244, 1));
}
