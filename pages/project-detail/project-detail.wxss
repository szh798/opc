.project-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f7f7f8;
}

.project-header {
  box-sizing: border-box;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(16, 16, 16, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background: rgba(255, 255, 255, 0.9);
}

.project-header__back {
  position: absolute;
  left: 26rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #282828;
}

.project-header__title {
  font-size: 36rpx;
  font-weight: 500;
  color: #171717;
}

.project-header__center {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.project-header__subtitle {
  margin-top: 3rpx;
  font-size: 22rpx;
  color: #737373;
}

.project-tabs {
  height: 90rpx;
  display: flex;
  border-bottom: 1rpx solid rgba(16, 16, 16, 0.1);
  background: rgba(255, 255, 255, 0.36);
}

.project-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: rgba(19, 19, 19, 0.6);
  border-bottom: 3rpx solid transparent;
  transition: color 0.2s ease, border-color 0.2s ease;
}

.project-tab--active {
  color: #121212;
  border-bottom-color: #111111;
  font-weight: 500;
}

.project-body {
  flex: 1;
  min-height: 0;
}

.project-panel {
  padding: 20rpx 22rpx;
}

.project-opportunity-panel {
  margin-bottom: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 250, 247, 0.96));
  border: 1rpx solid rgba(16, 163, 127, 0.18);
  box-shadow: 0 12rpx 30rpx rgba(16, 24, 40, 0.06);
}

.project-opportunity-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.project-opportunity-panel__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.project-opportunity-panel__badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(16, 163, 127, 0.1);
  color: #0f8f70;
  font-size: 24rpx;
  font-weight: 500;
}

.project-opportunity-panel__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.project-opportunity-panel__item {
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
}

.project-opportunity-panel__item--wide {
  width: 100%;
}

.project-opportunity-panel__label {
  display: block;
  font-size: 22rpx;
  color: rgba(17, 24, 39, 0.54);
}

.project-opportunity-panel__value {
  display: block;
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: #111827;
}

.project-cycle-tasks {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}

.project-cycle-task {
  color: #333333;
  font-size: 26rpx;
  line-height: 1.5;
}

.project-reminder-action {
  margin-top: 18rpx;
  display: inline-flex;
  align-items: center;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 600;
}

.project-row {
  display: flex;
}

.project-row + .project-row {
  margin-top: 14rpx;
}

.project-row--user {
  justify-content: flex-end;
}

.project-bubble {
  max-width: 86%;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  border: 1rpx solid #10a37f;
  background: #ffffff;
  font-size: 30rpx;
  line-height: 1.6;
  color: #161616;
}

.project-bubble--user {
  border-color: #0f0f0f;
  background: #121212;
  color: #ffffff;
}

.project-quick-replies {
  margin-top: 18rpx;
  width: 100%;
  white-space: nowrap;
}

.project-quick-replies__track {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 24rpx;
}

.project-reply {
  min-height: 88rpx;
  min-width: 156rpx;
  max-width: 520rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d0d5dd;
  background: #ffffff;
  display: inline-flex;
  align-items: center;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 500;
  color: #212121;
  flex-shrink: 0;
  justify-content: center;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
  writing-mode: horizontal-tb;
}

.project-panel--results {
  padding: 26rpx 22rpx 160rpx;
}

.artifact-filters {
  width: 100%;
  margin: 22rpx 0 24rpx;
  white-space: nowrap;
}

.artifact-filters__track {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 20rpx;
}

.artifact-filter {
  min-width: 94rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dddddf;
  background: #ffffff;
  color: #666666;
  font-size: 28rpx;
  line-height: 60rpx;
  text-align: center;
}

.artifact-filter--active {
  border-color: #0d0d0d;
  background: #0d0d0d;
  color: #ffffff;
}

.artifact-groups {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.artifact-group {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.artifact-group__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}

.artifact-group__title {
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #222222;
}

.artifact-group__count {
  font-size: 26rpx;
  color: #737373;
}

.artifact-empty {
  box-sizing: border-box;
  min-height: 270rpx;
  padding: 58rpx 34rpx;
  border: 1rpx solid #dcdde2;
  border-radius: 32rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.artifact-empty__title {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #0d0d0d;
}

.artifact-empty__desc {
  margin-top: 24rpx;
  max-width: 560rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: #737373;
}

.artifact-empty__button {
  margin-top: 30rpx;
  height: 62rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #0d0d0d;
  color: #ffffff;
  font-size: 27rpx;
  line-height: 62rpx;
}

.project-composer {
  padding: 12rpx 20rpx calc(env(safe-area-inset-bottom) + 16rpx);
  background: linear-gradient(180deg, rgba(243, 243, 244, 0), rgba(243, 243, 244, 0.95) 38%, rgba(243, 243, 244, 1));
}
