.preview-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 76rpx 28rpx 40rpx;
  background: #f7f7f8;
}

.preview-header {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}

.preview-kicker {
  font-size: 22rpx;
  line-height: 1.2;
  letter-spacing: 0.16em;
  color: #534ab7;
  font-weight: 700;
}

.preview-title {
  margin-top: 14rpx;
  font-size: 44rpx;
  line-height: 1.15;
  color: #171717;
  font-weight: 700;
}

.preview-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(23, 23, 23, 0.58);
}

.preview-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 12rpx;
}

.preview-button {
  flex: 1;
  height: 76rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 76rpx;
  font-weight: 600;
}

.preview-button::after {
  border: none;
}

.preview-button--ghost {
  background: #ececef;
  color: #1f1f1f;
}

.preview-note {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(83, 74, 183, 0.08);
  color: rgba(23, 23, 23, 0.62);
  font-size: 22rpx;
  line-height: 1.5;
}
