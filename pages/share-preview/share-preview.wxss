.share-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 24rpx) 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: #f7f7f8;
}

.share-preview-head__title {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #171717;
}

.share-preview-head__desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(26, 26, 26, 0.58);
}

.share-card {
  margin-top: 22rpx;
  border-radius: 28rpx;
  padding: 30rpx;
  background: #0a0a0a;
  color: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(12, 12, 12, 0.26);
}

.share-card__subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.42);
}

.share-card__title {
  display: block;
  margin-top: 20rpx;
  font-size: 56rpx;
  line-height: 1.2;
  font-weight: 500;
  white-space: pre-line;
}

.share-panel {
  margin-top: 36rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
}

.share-row + .share-row {
  margin-top: 14rpx;
}

.share-row__label {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.65);
}

.share-row__track {
  margin-top: 8rpx;
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.14);
}

.share-row__fill {
  height: 100%;
  border-radius: inherit;
  background: #6f5fe4;
}

.share-footer {
  margin-top: 48rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.share-footer__left {
  width: 68%;
}

.share-footer__quote {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.5);
}

.share-footer__brand {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.68);
}

.share-footer__qr {
  width: 128rpx;
  height: 128rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.42);
}

.share-caption {
  margin-top: 18rpx;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(20, 20, 20, 0.08);
}

.share-caption__label {
  display: block;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: rgba(21, 21, 21, 0.56);
}

.share-caption__text {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: #1a1a1a;
}

.share-tags {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.share-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ede8ff;
  color: #534ab7;
  font-size: 24rpx;
}

.share-caption__time {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(21, 21, 21, 0.46);
}

.share-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.share-action {
  flex: 1;
  height: 88rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.12);
  font-size: 30rpx;
  font-weight: 500;
}

.share-action::after {
  border: none;
}

.share-action--ghost {
  background: rgba(255, 255, 255, 0.7);
  color: #1c1c1c;
}

.share-action--primary {
  background: #111111;
  color: #ffffff;
}
