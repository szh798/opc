<view class="share-page">
  <view class="share-preview-head">
    <text class="share-preview-head__title">朋友圈分享预览</text>
    <text class="share-preview-head__desc">这张图会直接影响转发意愿，建议先看一遍再发。</text>
  </view>

  <state-view
    visible="{{loading}}"
    type="loading"
    title="正在生成分享图"
    desc="一树在排版你的成果亮点"
    mode="inline"
  />

  <state-view
    visible="{{!loading && error}}"
    type="error"
    title="分享图同步失败，已展示本地版本"
    actionText="重试"
    bind:action="handleRetry"
    mode="inline"
  />

  <state-view
    visible="{{!loading && !preview.bars.length}}"
    type="empty"
    title="暂无可分享数据"
    desc="先完成一张成果卡片，再来生成海报"
    mode="inline"
  />

  <view wx:if="{{!loading && preview.bars.length}}" class="share-card">
    <text class="share-card__subtitle">{{preview.subtitle}}</text>
    <text class="share-card__title">{{preview.title}}</text>

    <view class="share-panel">
      <view wx:for="{{preview.bars}}" wx:key="label" class="share-row">
        <text class="share-row__label">{{item.label}}</text>
        <view class="share-row__track">
          <view class="share-row__fill" style="width: {{item.value}}%;"></view>
        </view>
      </view>
    </view>

    <view class="share-footer">
      <view class="share-footer__left">
        <text class="share-footer__quote">{{preview.quote}}</text>
        <text class="share-footer__brand">{{preview.brand}}</text>
      </view>
      <view class="share-footer__qr">小程序码</view>
    </view>
  </view>

  <view wx:if="{{!loading && preview.bars.length}}" class="share-caption">
    <text class="share-caption__label">建议文案</text>
    <text class="share-caption__text">{{preview.caption}}</text>
    <view class="share-tags">
      <text wx:for="{{preview.hashtags}}" wx:key="*this" class="share-tag">{{item}}</text>
    </view>
    <text class="share-caption__time">{{preview.createdAt}}</text>
  </view>

  <view wx:if="{{!loading && preview.bars.length}}" class="share-actions">
    <button class="share-action share-action--ghost" bindtap="handleCopyCaption">复制文案</button>
    <button class="share-action share-action--primary" bindtap="handleSavePoster">保存海报</button>
  </view>
</view>
