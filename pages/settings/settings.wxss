.settings-page {
  height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(209, 228, 255, 0.72), transparent 30%),
    linear-gradient(180deg, #f8f6f1 0%, #f2f3f6 100%);
  display: flex;
  flex-direction: column;
}

.settings-header {
  box-sizing: border-box;
  padding: 0 28rpx 18rpx;
  display: flex;
  align-items: center;
}

.settings-back {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #2a2a2a;
  background: rgba(255, 255, 255, 0.54);
  border: 1rpx solid rgba(18, 18, 18, 0.08);
}

.settings-header__center {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
}

.settings-header__title {
  font-size: 40rpx;
  line-height: 1.18;
  font-weight: 600;
  color: #171717;
}

.settings-header__subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(25, 25, 25, 0.56);
}

.settings-scroll {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
}

.settings-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(18, 18, 18, 0.08);
  backdrop-filter: blur(14rpx);
}

.settings-card--hero {
  margin-top: 8rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(239, 244, 255, 0.92));
}

.settings-card--last {
  margin-bottom: 12rpx;
}

.settings-card__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #171717;
}

.settings-user {
  display: flex;
  align-items: center;
}

.settings-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background-color: #ffffff;
  background-image: url("/assets/images/default-avatar-atree.svg");
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
  color: transparent;
  font-size: 0;
  font-weight: 600;
}

.settings-avatar--image {
  background: #ffffff;
}

.settings-user__meta {
  margin-left: 18rpx;
  min-width: 0;
}

.settings-user__name {
  display: block;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #111111;
}

.settings-user__desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(20, 20, 20, 0.58);
}

.settings-badges {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.settings-badge {
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(16, 16, 16, 0.06);
  color: #1f1f1f;
  font-size: 24rpx;
}

.settings-row {
  min-height: 96rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(18, 18, 18, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.settings-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.settings-row--actions {
  gap: 12rpx;
}

.settings-row__main {
  flex: 1;
  min-width: 0;
}

.settings-row__label {
  display: block;
  font-size: 30rpx;
  line-height: 1.3;
  color: #151515;
  font-weight: 500;
}

.settings-row__value {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(26, 26, 26, 0.58);
  word-break: break-all;
}

.settings-row__arrow {
  font-size: 40rpx;
  color: rgba(24, 24, 24, 0.32);
}

.settings-btn {
  min-width: 168rpx;
  height: 76rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #141414;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 76rpx;
  font-weight: 500;
}

.settings-btn::after {
  border: none;
}

.settings-btn--ghost {
  background: rgba(18, 18, 18, 0.06);
  color: #1b1b1b;
}

.settings-btn--warn {
  background: rgba(218, 77, 55, 0.12);
  color: #b54331;
}

.settings-error {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #b2472d;
}

.settings-chat-list {
  margin-top: 14rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(17, 17, 17, 0.03);
}

.settings-chat-item {
  min-height: 76rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid rgba(18, 18, 18, 0.06);
  font-size: 26rpx;
  color: #1d1d1d;
}

.settings-chat-item:last-child {
  border-bottom: none;
}

.settings-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(28, 28, 28, 0.58);
}

.settings-runtime {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(28, 28, 28, 0.62);
  word-break: break-all;
}
