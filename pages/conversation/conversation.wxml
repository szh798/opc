<view class="conversation-page theme-agent-{{agentKey}}">
  <view class="conversation-header-anchor">
    <app-header
      agentKey="{{agentKey}}"
      userAvatarUrl="{{user.avatarUrl || ''}}"
      showTree="{{false}}"
      bind:avatartap="handleAvatarTap"
      bind:agenttap="handleAgentTap"
      bind:profiletap="handleProfileTap"
      bind:treepulldown="handleTreePullDown"
    />
  </view>

  <view wx:if="{{agentMenuVisible}}" class="agent-menu-layer">
    <view class="agent-menu-mask" bindtap="handleAgentMenuClose"></view>
    <view class="agent-menu-card" style="{{agentMenuStyle}}" catchtap="handleAgentMenuHold">
      <block wx:for="{{agentMenuOptions}}" wx:key="key">
        <view
          id="agent-menu-item-{{item.key}}"
          class="agent-menu-item {{item.disabled ? 'agent-menu-item--disabled' : ''}}"
          data-key="{{item.key}}"
          data-disabled="{{item.disabled}}"
          bindtap="handleAgentSelect"
        >
          <view class="agent-menu-item__dot" style="background: {{item.disabled ? '#bcbcbc' : item.color}};"></view>
          <text class="agent-menu-item__label">{{item.label}}</text>
          <text class="agent-menu-item__check {{item.key === agentKey ? 'agent-menu-item__check--active' : ''}}">✓</text>
        </view>
      </block>
    </view>
  </view>

  <view class="conversation-body">
    <scroll-view
      class="conversation-scroll"
      scroll-y
      enable-flex
      scroll-with-animation
      scroll-into-view="{{scrollIntoView}}"
    >
      <view class="message-stream">
        <state-view
          visible="{{bootLoading}}"
          type="loading"
          title="正在连接一树"
          desc="拉取最近对话与项目中"
          mode="inline"
        />

        <state-view
          visible="{{!bootLoading && bootError}}"
          type="error"
          title="启动数据拉取失败"
          desc="当前没有回退本地数据，请检查后端和网络后重试"
          mode="inline"
        />

        <block wx:for="{{messages}}" wx:key="_uid" wx:for-item="message">
          <view
            id="msg-{{message._uid}}"
            class="message-row {{message.type === 'user' ? 'message-row--user' : 'message-row--agent'}}"
          >
            <message-bubble
              wx:if="{{message.type === 'agent'}}"
              variant="agent"
              text="{{message.text}}"
              compact="{{message.uiMode === 'processing'}}"
              borderColor="{{agentColor}}"
            />

            <message-bubble
              wx:elif="{{message.type === 'user'}}"
              variant="user"
              text="{{message.text}}"
            />

            <typing-indicator wx:elif="{{message.type === 'typing'}}" />

            <login-card
              wx:elif="{{message.type === 'login_card'}}"
              mode="{{message.mode || 'pending'}}"
              title="{{message.title}}"
              description="{{message.description}}"
              buttonText="{{message.buttonText}}"
              showDevFreshButton="{{showDevFreshLogin}}"
              devFreshButtonText="模拟新用户登录"
              userName="{{message.userName || user.nickname || user.name}}"
              userAvatarUrl="{{message.userAvatarUrl || user.avatarUrl || ''}}"
              bind:action="handleLoginAction"
              bind:devfreshaction="handleDevFreshLoginAction"
              bind:loginsuccess="handleLoginSuccess"
              bind:smslogintap="handleSmsLoginTap"
              bind:agreementtap="handleAgreementTap"
            />

            <daily-tasks-card
              wx:elif="{{message.type === 'task_card'}}"
              title="{{message.title || 'Suggestion'}}"
              items="{{message.items}}"
              bind:taskaction="handleDailyTaskAction"
            />

            <view wx:elif="{{message.type === 'opportunity_hub_card'}}" class="opportunity-hub-card">
              <view class="opportunity-hub-card__top">
                <text class="opportunity-hub-card__eyebrow">挖宝工作台</text>
                <text class="opportunity-hub-card__status">{{message.statusLabel}}</text>
              </view>
              <text class="opportunity-hub-card__title">{{message.title}}</text>
              <text wx:if="{{message.subtitle}}" class="opportunity-hub-card__subtitle">{{message.subtitle}}</text>
              <view class="opportunity-hub-card__steps">
                <block wx:for="{{message.steps}}" wx:key="*this">
                  <view class="opportunity-hub-card__step">
                    <text class="opportunity-hub-card__step-index">{{index + 1}}</text>
                    <text class="opportunity-hub-card__step-text">{{item}}</text>
                  </view>
                </block>
              </view>
              <view
                class="opportunity-hub-card__action"
                data-action="{{message.primaryAction}}"
                data-project-id="{{message.projectId}}"
                data-workspace-version="{{message.workspaceVersion}}"
                bindtap="handleOpportunityHubPrimaryAction"
              >{{message.primaryText}}</view>
            </view>

            <view wx:elif="{{message.type === 'business_direction_card_v2'}}" class="business-card">
              <text class="business-card__title">{{message.title}}</text>
              <block wx:for="{{message.directions}}" wx:key="directionId">
                <view class="business-card__item">
                  <text class="business-card__item-title">{{item.title}}</text>
                  <text class="business-card__line">对象：{{item.targetUser}}</text>
                  <text class="business-card__line">痛点：{{item.corePain}}</text>
                  <text class="business-card__line">首个信号：{{item.estimatedTimeToFirstSignal}} · 成本：{{item.validationCost}} · 难度：{{item.executionDifficulty}}</text>
                  <text class="business-card__line">停止信号：{{item.killSignal}}</text>
                  <view
                    class="business-card__action{{selectingDirectionId === item.directionId ? ' business-card__action--busy' : ''}}"
                    data-project-id="{{message.projectId}}"
                    data-candidate-set-id="{{message.candidateSetId}}"
                    data-direction-id="{{item.directionId}}"
                    data-workspace-version="{{message.workspaceVersion}}"
                    bindtap="handleBusinessDirectionSelect"
                  >{{selectingDirectionId === item.directionId ? '正在深聊…' : '选这个方向深聊'}}</view>
                </view>
              </block>
              <view
                class="business-card__secondary"
                data-project-id="{{message.projectId}}"
                data-workspace-version="{{message.workspaceVersion}}"
                bindtap="handleBusinessDirectionsRefresh"
              >换一组方向</view>
            </view>

            <view wx:elif="{{message.type === 'initiation_summary_card_v2'}}" class="business-card">
              <text class="business-card__title">{{message.summary.projectName || message.title}}</text>
              <text class="business-card__line">{{message.summary.oneLinePositioning}}</text>
              <text class="business-card__line">首轮目标：{{message.summary.firstCycleGoal}}</text>
              <text class="business-card__line">成功标准：{{message.successCriteriaText}}</text>
              <text class="business-card__line">停止标准：{{message.killCriteriaText}}</text>
              <text class="business-card__line">需要证据：{{message.evidenceNeededText}}</text>
              <view
                class="business-card__action"
                data-project-id="{{message.projectId}}"
                data-workspace-version="{{message.workspaceVersion}}"
                data-summary-version="{{message.initiationSummaryVersion}}"
                bindtap="handleProjectInitiate"
              >确认立项</view>
            </view>

            <view wx:elif="{{message.type === 'project_success_card_v2'}}" class="business-card business-card--success">
              <text class="business-card__title">{{message.title}}</text>
              <text class="business-card__line">{{message.projectName}}</text>
              <text class="business-card__line">本轮目标：{{message.goal}}</text>
              <block wx:for="{{message.tasks}}" wx:key="id">
                <text class="business-card__line">· {{item.label}}</text>
              </block>
              <view class="business-card__action" data-id="{{message.projectId}}" bindtap="handleProjectTap">进入项目详情</view>
              <view class="business-card__secondary" data-project-id="{{message.projectId}}" bindtap="handleProjectFollowupSubscribe">开启 3 天提醒</view>
            </view>

            <view wx:elif="{{message.type === 'business_direction_card'}}" class="business-card">
              <text class="business-card__title">{{message.title}}</text>
              <block wx:for="{{message.directions}}" wx:key="directionId">
                <view class="business-card__item">
                  <text class="business-card__item-title">{{item.title}}</text>
                  <text class="business-card__line">对象：{{item.targetUser}}</text>
                  <text class="business-card__line">痛点：{{item.corePain}}</text>
                  <text class="business-card__line">首个信号：{{item.estimatedTimeToFirstSignal}} · 成本：{{item.validationCost}} · 难度：{{item.executionDifficulty}}</text>
                  <text class="business-card__line">停止信号：{{item.killSignal}}</text>
                  <view
                    class="business-card__action{{selectingDirectionId === item.directionId ? ' business-card__action--busy' : ''}}"
                    data-project-id="{{message.projectId}}"
                    data-candidate-set-id="{{message.candidateSetId}}"
                    data-direction-id="{{item.directionId}}"
                    data-workspace-version="{{message.workspaceVersion}}"
                    bindtap="handleBusinessDirectionSelect"
                  >{{selectingDirectionId === item.directionId ? '正在深聊…' : '选这个方向深聊'}}</view>
                </view>
              </block>
              <view
                class="business-card__secondary"
                data-project-id="{{message.projectId}}"
                data-workspace-version="{{message.workspaceVersion}}"
                bindtap="handleBusinessDirectionsRefresh"
              >换一组方向</view>
            </view>

            <view wx:elif="{{message.type === 'initiation_summary_card'}}" class="business-card">
              <text class="business-card__title">{{message.summary.projectName || message.title}}</text>
              <text class="business-card__line">{{message.summary.oneLinePositioning}}</text>
              <text class="business-card__line">首轮目标：{{message.summary.firstCycleGoal}}</text>
              <text class="business-card__line">成功标准：{{message.successCriteriaText}}</text>
              <text class="business-card__line">停止标准：{{message.killCriteriaText}}</text>
              <text class="business-card__line">需要证据：{{message.evidenceNeededText}}</text>
              <view
                class="business-card__action"
                data-project-id="{{message.projectId}}"
                data-workspace-version="{{message.workspaceVersion}}"
                data-summary-version="{{message.initiationSummaryVersion}}"
                bindtap="handleProjectInitiate"
              >确认立项</view>
            </view>

            <view wx:elif="{{message.type === 'project_success_card'}}" class="business-card business-card--success">
              <text class="business-card__title">{{message.title}}</text>
              <text class="business-card__line">{{message.projectName}}</text>
              <text class="business-card__line">本轮目标：{{message.goal}}</text>
              <block wx:for="{{message.tasks}}" wx:key="id">
                <text class="business-card__line">· {{item.label}}</text>
              </block>
              <view class="business-card__action" data-id="{{message.projectId}}" bindtap="handleProjectTap">进入项目详情</view>
              <view class="business-card__secondary" data-project-id="{{message.projectId}}" bindtap="handleProjectFollowupSubscribe">开启 3 天提醒</view>
            </view>

            <leverage-card
              wx:elif="{{message.type === 'leverage_card'}}"
              paragraphs="{{message.paragraphs}}"
              primaryText="{{message.primaryText}}"
              secondaryText="{{message.secondaryText}}"
              bind:primary="handleLeveragePrimary"
              bind:secondary="handleLeverageSecondary"
            />

            <asset-report-progress-card
              wx:elif="{{message.type === 'asset_report_progress'}}"
              card-id="{{message.cardId}}"
              card-data="{{message.data}}"
            />

            <artifact-card
              wx:elif="{{message.type === 'artifact_card'}}"
              id="artifact-card-{{message.primaryAction || message.cardType || 'default'}}"
              title="{{message.title}}"
              description="{{message.description}}"
              tags="{{message.tags || []}}"
              meta="{{message.meta || ''}}"
              primaryText="{{message.primaryText || ''}}"
              secondaryText="{{message.secondaryText || ''}}"
              primaryAction="{{message.primaryAction || ''}}"
              secondaryAction="{{message.secondaryAction || ''}}"
              cardType="{{message.cardType || ''}}"
              cardStyle="{{message.cardStyle || 'default'}}"
              data-action="{{message.primaryAction || ''}}"
              data-secondary-action="{{message.secondaryAction || ''}}"
              data-card-type="{{message.cardType || ''}}"
              bind:primary="handleArtifactPrimary"
              bind:secondary="handleArtifactSecondary"
            />

            <policy-opportunity-card
              wx:elif="{{message.type === 'policy_opportunity_card'}}"
              title="{{message.title}}"
              description="{{message.description}}"
              cardType="{{message.cardType}}"
              payload="{{message.payload}}"
              actions="{{message.actions || []}}"
              primaryText="{{message.primaryText || ''}}"
              secondaryText="{{message.secondaryText || ''}}"
              primaryAction="{{message.primaryAction || ''}}"
              secondaryAction="{{message.secondaryAction || ''}}"
              bind:action="handlePolicyCardAction"
            />

            <report-card
              wx:elif="{{message.type === 'report_card'}}"
              variant="{{message.variant}}"
              title="{{message.title}}"
              stats="{{message.stats || []}}"
              metrics="{{message.metrics || []}}"
              comment="{{message.comment || ''}}"
              comparison="{{message.comparison || ''}}"
              advice="{{message.advice || ''}}"
              primaryText="{{message.primaryText || ''}}"
              primaryAction="{{message.primaryAction || ''}}"
              bind:primary="handleReportPrimary"
            />

            <milestone-card
              wx:elif="{{message.type === 'milestone_card'}}"
              title="{{message.title}}"
              unlocked="{{message.unlocked}}"
              copy="{{message.copy}}"
              primaryText="{{message.primaryText}}"
              secondaryText="{{message.secondaryText}}"
              bind:primary="handleMilestonePrimary"
              bind:secondary="handleMilestoneSecondary"
            />

            <social-proof-card
              wx:elif="{{message.type === 'social_proof_card'}}"
              headline="{{message.headline}}"
              proofTitle="{{message.proofTitle || '同路人数据'}}"
              proof="{{message.proof}}"
              proofStats="{{message.proofStats || []}}"
              nudge="{{message.nudge}}"
              primaryText="{{message.primaryText}}"
              secondaryText="{{message.secondaryText}}"
              bind:primary="handleSocialPrimary"
              bind:secondary="handleSocialSecondary"
            />

            <view wx:elif="{{message.type === 'next_question_card'}}" class="next-question-card">
              <text class="next-question-card__title">{{message.title || '下一步建议'}}</text>
              <text class="next-question-card__question">{{message.question}}</text>
              <view
                class="next-question-card__action"
                data-question="{{message.question}}"
                data-message-id="{{message.id}}"
                bindtap="handleNextQuestionAction"
              >
                <text class="next-question-card__action-text">{{message.actionText || '按这个继续'}}</text>
              </view>
            </view>

            <view wx:elif="{{message.type === 'status_chip'}}" class="status-chip">
              <view class="status-chip__check">✓</view>
              <text class="status-chip__label">{{message.label}}</text>
              <text class="status-chip__done">{{message.status}}</text>
            </view>
          </view>
        </block>

        <quick-replies items="{{quickReplies}}" bind:select="handleQuickReplySelect" />
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{allowInput}}" class="conversation-footer">
    <bottom-input
      placeholder="{{inputPlaceholder}}"
      streaming="{{isStreaming}}"
      bind:plustap="handlePlusTap"
      bind:send="handleSend"
      bind:stop="handleStopStream"
    />
  </view>

  <app-sidebar
    visible="{{sidebarVisible}}"
    user="{{user}}"
    projects="{{projects}}"
    tools="{{tools}}"
    activeToolKey="{{activeToolKey}}"
    recentChats="{{recentChats}}"
    bind:close="handleSidebarClose"
    bind:profiletap="handleProfileTap"
    bind:newchat="handleNewChat"
    bind:tooltap="handleToolTap"
    bind:projecttap="handleProjectTap"
    bind:recenttap="handleRecentTap"
    bind:recentdelete="handleRecentDelete"
    bind:settingtap="handleSettingTap"
    bind:helptap="handleHelpTap"
  />

  <project-sheet
    visible="{{projectSheetVisible}}"
    projects="{{projects}}"
    bind:close="handleProjectSheetClose"
    bind:projecttap="handleProjectTap"
    bind:create="handleProjectCreate"
  />

  <view wx:if="{{comingSoonNoticeVisible}}" class="coming-soon-notice">
    <view class="coming-soon-notice__card">
      <text class="coming-soon-notice__text">{{comingSoonNoticeText}}</text>
    </view>
  </view>
</view>
