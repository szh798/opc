@import "../../theme/tokens.wxss";

.conversation-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f7f7f8;
}

.conversation-header-anchor {
  flex-shrink: 0;
}

.conversation-body {
  flex: 1;
  min-height: 0;
}

.conversation-scroll {
  height: 100%;
}

.message-stream {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 16rpx 24rpx 12rpx;
}

.message-row {
  display: flex;
  justify-content: flex-start;
}

.message-row--user {
  justify-content: flex-end;
  padding-left: 0;
}

.message-row--user .message-bubble--user {
  margin-left: auto;
  margin-right: -12rpx;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(16, 16, 16, 0.1);
  background: #ffffff;
}

.status-chip__check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #10a37f;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
}

.status-chip__label {
  font-size: 30rpx;
  color: #1a1a1a;
}

.status-chip__done {
  font-size: 28rpx;
  color: #10a37f;
  font-weight: 500;
}

.next-question-card {
  width: 100%;
  max-width: 620rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 16, 16, 0.08);
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.next-question-card__title {
  font-size: 24rpx;
  color: #8a8a8a;
}

.next-question-card__question {
  font-size: 30rpx;
  color: #111111;
  line-height: 1.5;
}

.next-question-card__action {
  align-self: flex-start;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #0d0d0d;
}

.next-question-card__action-text {
  font-size: 24rpx;
  color: #ffffff;
  line-height: 1.2;
}

.conversation-footer {
  padding: 10rpx 18rpx calc(env(safe-area-inset-bottom) + 12rpx);
  background:
    linear-gradient(180deg, rgba(247, 247, 248, 0), rgba(247, 247, 248, 0.95) 40%, rgba(247, 247, 248, 1));
}

.coming-soon-notice {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 80;
  pointer-events: none;
}

.coming-soon-notice__card {
  max-width: 520rpx;
  padding: 24rpx 30rpx;
  border-radius: 24rpx;
  background: rgba(17, 17, 17, 0.88);
  box-shadow: 0 16rpx 44rpx rgba(0, 0, 0, 0.18);
}

.coming-soon-notice__text {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: center;
}

.agent-menu-layer {
  position: fixed;
  inset: 0;
  z-index: 36;
}

.agent-menu-mask {
  position: absolute;
  inset: 0;
  background: rgba(16, 16, 16, 0.08);
}

.agent-menu-card {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: auto;
  max-width: calc(100vw - 48rpx);
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.agent-menu-item {
  width: auto;
  min-height: 66rpx;
  padding: 0 22rpx;
  margin-bottom: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 1rpx solid rgba(16, 16, 16, 0.12);
  border-radius: 999rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.agent-menu-item--disabled {
  background: #f2f2f2;
  border-color: #e6e6e6;
}

.agent-menu-item--disabled .agent-menu-item__label {
  color: #9a9a9a;
}

.agent-menu-item--disabled .agent-menu-item__check {
  color: #b7b7b7;
}

.agent-menu-item:last-child {
  margin-bottom: 0;
}

.agent-menu-item + .agent-menu-item {
  margin-top: -1rpx;
}

.agent-menu-item__dot {
  width: 22rpx;
  height: 22rpx;
  flex: 0 0 22rpx;
  border-radius: 999rpx;
}

.agent-menu-item__label {
  min-width: 0;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #111111;
  white-space: nowrap;
}

.agent-menu-item__check {
  width: 30rpx;
  flex: 0 0 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #10a37f;
  font-weight: 600;
  opacity: 0;
}

.agent-menu-item__check--active {
  opacity: 1;
}

.opportunity-hub-card {
  width: 100%;
  max-width: 646rpx;
  box-sizing: border-box;
  padding: 26rpx 28rpx 28rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 22rpx;
  color: #111111;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.05);
}

.opportunity-hub-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.opportunity-hub-card__eyebrow,
.opportunity-hub-card__status {
  font-size: 24rpx;
  line-height: 1.2;
  color: #6b7280;
}

.opportunity-hub-card__status {
  padding: 8rpx 16rpx;
  border: 1rpx solid #ececec;
  border-radius: 999rpx;
  color: #525252;
  background: #f7f7f8;
}

.opportunity-hub-card__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 600;
  letter-spacing: -0.4rpx;
}

.opportunity-hub-card__subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #4b5563;
}

.opportunity-hub-card__steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 24rpx;
  border-top: 1rpx solid #eeeeee;
  border-bottom: 1rpx solid #eeeeee;
}

.opportunity-hub-card__step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 0;
  border-radius: 0;
  background: transparent;
}

.opportunity-hub-card__step + .opportunity-hub-card__step {
  border-top: 1rpx solid #f2f2f2;
}

.opportunity-hub-card__step-index {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 36rpx;
  font-size: 22rpx;
  color: #525252;
  background: #f3f4f6;
}

.opportunity-hub-card__step-text {
  min-width: 0;
  font-size: 27rpx;
  line-height: 1.45;
  color: #262626;
}

.opportunity-hub-card__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 16rpx 26rpx;
  border-radius: 18rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
  background: #111111;
}

.business-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  max-width: 646rpx;
  box-sizing: border-box;
  padding: 26rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.05);
}

.business-card--success {
  border-color: #d1d5db;
}

.business-card__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #151515;
}

.business-card__item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #ece8df;
}

.business-card__item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #151515;
}

.business-card__line {
  font-size: 26rpx;
  line-height: 1.55;
  color: #333;
  white-space: pre-wrap;
}

.business-card__action,
.business-card__secondary {
  align-self: flex-start;
  padding: 14rpx 22rpx;
  border-radius: 18rpx;
  font-size: 25rpx;
  font-weight: 600;
}

.business-card__action {
  color: #fff;
  background: #111111;
}

.business-card__action--busy {
  opacity: 0.68;
}

.business-card__secondary {
  color: #111111;
  border: 1rpx solid #e5e5e5;
  background: #f7f7f8;
}
