<chat-shell
  agentKey="{{agentKey}}"
  user="{{user}}"
  sidebarVisible="{{sidebarVisible}}"
  projects="{{projects}}"
  tools="{{tools}}"
  recentChats="{{recentChats}}"
  inputPlaceholder="{{inputPlaceholder}}"
  bind:avatartap="handleAvatarTap"
  bind:sidebarclose="handleSidebarClose"
  bind:profiletap="handleProfileTap"
  bind:projecttap="handleProjectTap"
  bind:tooltap="handleToolTap"
  bind:treetap="handleTreeTap"
  bind:plustap="handlePlusTap"
  bind:send="handleSend"
  bind:newchat="handleNewChat"
  bind:recenttap="handleRecentTap"
>
  <view slot="content" class="message-stream">
    <block wx:for="{{messages}}" wx:key="id" wx:for-item="message">
      <view wx:if="{{message.sender === 'agent'}}" class="message-row message-row--agent">
        <view class="bubble bubble--agent" style="border-color: {{agentColor}};">
          <text>{{message.text}}</text>
        </view>
      </view>

      <view wx:elif="{{message.sender === 'user'}}" class="message-row message-row--user">
        <view class="bubble bubble--user">
          <text>{{message.text}}</text>
        </view>
      </view>

      <view wx:elif="{{message.sender === 'task'}}" class="message-row message-row--card">
        <view class="message-card">
          <text class="message-card__title">{{message.title}}</text>

          <view class="task-list">
            <block wx:for="{{message.items}}" wx:key="label" wx:for-item="task">
              <view class="task-item">
                <view class="task-item__left">
                  <view class="task-checkbox"></view>
                  <text class="task-item__text">{{task.label}}</text>
                </view>
                <text class="task-item__tag">{{task.tag}}</text>
              </view>
            </block>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{quickReplies.length}}" class="quick-replies">
      <view wx:for="{{quickReplies}}" wx:key="*this" class="quick-reply" data-label="{{item}}" bindtap="handleQuickReply">
        {{item}}
      </view>
    </view>
  </view>
</chat-shell>

<project-sheet
  visible="{{projectSheetVisible}}"
  projects="{{projects}}"
  bind:close="handleProjectSheetClose"
  bind:projecttap="handleProjectTap"
  bind:create="handleCreateProject"
/>

<company-panel
  visible="{{companyPanelVisible}}"
  cards="{{companyCards}}"
  bind:close="handleCompanyClose"
  bind:actiontap="handleCompanyAction"
/>
