@import "../../theme/chat-page.wxss";

.message-row--user {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.chat-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #d9e8fb;
  color: #3b6eb5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  flex-shrink: 0;
}
