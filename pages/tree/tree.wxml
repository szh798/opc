<view class="tree-page">
  <view class="tree-topbar" style="{{topbarStyle}}">
    <view class="tree-topbar__slot tree-topbar__slot--left">
      <view class="tree-topbar__close" bindtap="handleClose">X</view>
    </view>
    <view class="tree-topbar__slot tree-topbar__slot--center">
      <text class="tree-topbar__title">{{phaseInfo.title}}</text>
    </view>
    <view class="tree-topbar__slot tree-topbar__slot--right">
      <view class="tree-topbar__tag">{{phaseInfo.tag}}</view>
    </view>
  </view>

  <view class="tree-subtitle">{{phaseInfo.subtitle}}</view>

  <scroll-view class="tree-scroll" scroll-y>
    <view class="tree-content">
      <view class="tree-visual-card">
        <view class="tree-visual">
          <view class="tree-layer tree-layer--trunk {{revealStage >= 1 ? 'tree-layer--visible' : ''}}">
            <view class="tree-trunk"></view>
            <view class="tree-trunk-marks"></view>
            <view class="tree-ground"></view>
          </view>

          <view class="tree-layer tree-layer--branch {{revealStage >= 2 ? 'tree-layer--visible' : ''}}">
            <block wx:for="{{branches}}" wx:key="id">
              <view class="tree-branch tree-branch--{{item.side}}" style="{{item.style}}"></view>
            </block>
          </view>

          <view class="tree-layer tree-layer--leaf {{revealStage >= 3 ? 'tree-layer--visible' : ''}}">
            <block wx:for="{{leaves}}" wx:key="id">
              <view
                class="tree-leaf tree-leaf--{{item.status}} {{index < leafVisibleCount ? 'tree-leaf--visible' : ''}} {{item.clickable ? 'tree-leaf--tap' : ''}}"
                style="{{item.style}}"
                data-index="{{index}}"
                bindtap="handleLeafTap"
              ></view>
            </block>
          </view>
        </view>
        <text class="tree-caption">{{phaseInfo.caption}}</text>
      </view>

      <view class="timeline-card">
        <text class="timeline-card__title">成长里程碑</text>
        <block wx:for="{{milestones}}" wx:key="id">
          <view class="timeline-item timeline-item--{{item.status}}">
            <view class="timeline-axis">
              <view class="timeline-dot timeline-dot--{{item.status}}">
                <text wx:if="{{item.status === 'done'}}" class="timeline-dot__tick">✓</text>
                <view wx:if="{{item.status === 'doing'}}" class="timeline-dot__inner"></view>
              </view>
              <view wx:if="{{!item.isLast}}" class="timeline-line timeline-line--{{item.nextLineStatus}}"></view>
            </view>

            <view class="timeline-main">
              <text class="timeline-main__title">{{item.title}}</text>
              <text class="timeline-main__meta">{{item.meta}}</text>
            </view>

            <text class="timeline-status timeline-status--{{item.status}}">{{item.statusText}}</text>
          </view>
        </block>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{artifactVisible && selectedMilestone}}" class="artifact-layer" catchtouchmove="noop">
    <view class="artifact-mask" bindtap="handleArtifactClose"></view>
    <view class="artifact-sheet">
      <view class="artifact-sheet__header">
        <view class="artifact-sheet__title-wrap">
          <text class="artifact-stage">{{selectedMilestone.stageText}}</text>
          <text class="artifact-title">{{selectedMilestone.title}}</text>
        </view>
        <view class="artifact-close" bindtap="handleArtifactClose">X</view>
      </view>

      <text class="artifact-summary">{{selectedMilestone.summary}}</text>
      <result-card item="{{selectedMilestone.resultCard}}" bind:ctatap="handleArtifactAction" />

      <view class="artifact-action" bindtap="handleArtifactAction">回到聊天继续推进</view>
    </view>
  </view>
</view>
