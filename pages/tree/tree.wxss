page {
  background: #f3f4f6;
}

.tree-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f3f4f6;
}

.tree-topbar {
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 148rpx 1fr 148rpx;
  align-items: center;
  min-height: 96rpx;
  padding-left: 26rpx;
  padding-right: 26rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.08);
  background: #f6f7f9;
}

.tree-topbar__slot {
  min-width: 0;
  display: flex;
  align-items: center;
}

.tree-topbar__slot--left {
  justify-content: flex-start;
}

.tree-topbar__slot--center {
  justify-content: center;
}

.tree-topbar__slot--right {
  justify-content: flex-end;
}

.tree-topbar__close {
  width: 64rpx;
  font-size: 42rpx;
  line-height: 1;
  color: #5f6268;
  text-align: left;
}

.tree-topbar__title {
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #17191d;
  text-align: center;
  white-space: nowrap;
}

.tree-topbar__tag {
  min-width: 132rpx;
  height: 50rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #70737a;
  background: rgba(17, 17, 17, 0.06);
}

.tree-subtitle {
  padding: 24rpx 28rpx 12rpx;
  font-size: 30rpx;
  line-height: 1.42;
  text-align: center;
  color: #43464d;
}

.tree-scroll {
  flex: 1;
  min-height: 0;
}

.tree-content {
  padding: 0 24rpx calc(26rpx + env(safe-area-inset-bottom));
}

.tree-hero {
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 0.32s ease, transform 0.32s ease;
}

.tree-hero--visible {
  opacity: 1;
  transform: translateY(0);
}

.tree-visual-stage {
  position: relative;
  width: 100%;
  min-height: 520px;
  overflow: hidden;
}

.tree-full-image {
  position: absolute;
  left: 50%;
  top: 0;
  width: 100%;
  height: 100%;
  transform: translateX(-50%);
}

.tree-reveal-cover {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  background: #f3f4f6;
  transition: height 920ms cubic-bezier(0.2, 0.6, 0.2, 1);
  pointer-events: none;
}

.tree-leaf-hotspot {
  position: absolute;
  width: 32px;
  height: 32px;
  margin-left: -16px;
  margin-top: -16px;
  border-radius: 999rpx;
  border: 0;
  background: rgba(0, 0, 0, 0.001);
  opacity: 0;
  pointer-events: none;
}

.tree-leaf-hotspot--done {
  border: 0;
  background: rgba(0, 0, 0, 0.001);
}

.tree-leaf-hotspot--doing {
  border: 0;
  background: rgba(0, 0, 0, 0.001);
  box-shadow: none;
}

.tree-leaf-hotspot--locked {
  opacity: 0;
}

.tree-leaf-hotspot--tap {
  pointer-events: auto;
}

.tree-caption {
  display: block;
  margin-top: 4rpx;
  margin-bottom: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8a8d94;
}

.timeline-card {
  margin-top: 14rpx;
  padding: 22rpx 22rpx 8rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 24rpx;
  background: #f8f9fb;
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 0.28s ease, transform 0.28s ease;
}

.timeline-card--visible {
  opacity: 1;
  transform: translateY(0);
}

.timeline-card__title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e2023;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.timeline-item--locked {
  opacity: 0.48;
}

.timeline-axis {
  width: 38rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timeline-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.timeline-dot--done {
  background: #10a37f;
}

.timeline-dot--doing {
  background: #eba327;
}

.timeline-dot--locked {
  border: 2rpx solid #d3d7dd;
  background: transparent;
}

.timeline-dot__tick {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}

.timeline-dot__inner {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.timeline-line {
  margin-top: 8rpx;
  width: 4rpx;
  min-height: 50rpx;
  border-radius: 999rpx;
}

.timeline-line--done {
  background: #10a37f;
}

.timeline-line--doing {
  background: #eba327;
}

.timeline-line--locked {
  background: repeating-linear-gradient(to bottom, #d5d9de 0 8rpx, transparent 8rpx 16rpx);
}

.timeline-main {
  flex: 1;
  min-width: 0;
  padding-bottom: 20rpx;
}

.timeline-main__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.34;
  color: #1a1c20;
  font-weight: 500;
}

.timeline-main__meta {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #7f848c;
}

.timeline-status {
  min-width: 104rpx;
  padding-top: 2rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.3;
}

.timeline-status--done {
  color: #0d9a77;
}

.timeline-status--doing {
  color: #cb8a16;
}

.timeline-status--locked {
  color: #9ca1a8;
}

.artifact-layer {
  position: fixed;
  inset: 0;
  z-index: 80;
}

.artifact-mask {
  position: absolute;
  inset: 0;
  background: rgba(11, 13, 16, 0.26);
}

.artifact-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 68vh;
  border-radius: 30rpx 30rpx 0 0;
  padding: 24rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f7f8fa;
  overflow-y: auto;
}

.artifact-sheet__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.artifact-sheet__title-wrap {
  flex: 1;
  min-width: 0;
}

.artifact-stage {
  display: block;
  font-size: 24rpx;
  color: #7b8189;
}

.artifact-title {
  display: block;
  margin-top: 6rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #171a1d;
}

.artifact-close {
  width: 48rpx;
  text-align: center;
  font-size: 34rpx;
  line-height: 1;
  color: #656a72;
}

.artifact-summary {
  display: block;
  margin-top: 12rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #49505a;
}

.artifact-action {
  margin-top: 16rpx;
  height: 82rpx;
  border-radius: 18rpx;
  background: #111315;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
