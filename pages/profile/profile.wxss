.profile-page {
  height: 100vh;
  background: #f7f7f8;
  display: flex;
  flex-direction: column;
}

.profile-header {
  padding: calc(env(safe-area-inset-top) + 18rpx) 28rpx 18rpx;
  border-bottom: 1rpx solid rgba(20, 20, 20, 0.08);
  background: rgba(255, 255, 255, 0.74);
  display: flex;
  align-items: center;
}

.profile-back {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #2a2a2a;
}

.profile-header__center {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}

.profile-header__title {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #181818;
}

.profile-header__byline {
  font-size: 30rpx;
  color: rgba(26, 26, 26, 0.56);
}

.profile-scroll {
  flex: 1;
  min-height: 0;
  padding: 28rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
}

.profile-user {
  padding: 18rpx 0 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 138rpx;
  height: 138rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d9e8fb;
  color: #3b6eb5;
  font-size: 64rpx;
  font-weight: 500;
}

.profile-avatar--image {
  background: #d9e8fb;
}

.profile-name {
  margin-top: 18rpx;
  font-size: 50rpx;
  line-height: 1.15;
  font-weight: 500;
  color: #1a1a1a;
}

.profile-stage {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: rgba(31, 31, 31, 0.58);
}

.profile-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.1);
  background: rgba(255, 255, 255, 0.88);
}

.profile-card--last {
  margin-bottom: 10rpx;
}

.profile-card__title {
  display: block;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #171717;
}

.dev-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.dev-cell {
  width: calc(50% - 7rpx);
  box-sizing: border-box;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(18, 18, 18, 0.04);
}

.dev-cell__label {
  display: block;
  font-size: 22rpx;
  color: rgba(24, 24, 24, 0.54);
}

.dev-cell__value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.35;
  color: #151515;
  font-weight: 500;
}

.dev-meta {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(88, 83, 72, 0.06);
}

.dev-meta__text {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: rgba(27, 27, 27, 0.68);
  word-break: break-all;
}

.dev-meta__text + .dev-meta__text {
  margin-top: 6rpx;
}

.dev-error {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #b2472d;
}

.dev-actions {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dev-btn {
  width: 100%;
  height: 82rpx;
  border-radius: 18rpx;
  background: rgba(19, 19, 19, 0.06);
  color: #171717;
  font-size: 28rpx;
  line-height: 82rpx;
  font-weight: 500;
}

.dev-btn::after {
  border: none;
}

.dev-btn--dark {
  background: #111111;
  color: #ffffff;
}

.dev-btn--warn {
  background: rgba(184, 71, 45, 0.1);
  color: #a13a23;
}

.radar-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.radar-row__label {
  width: 70rpx;
  font-size: 28rpx;
  color: #272727;
}

.radar-row__track {
  flex: 1;
  height: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #ecebe6;
}

.radar-row__fill {
  height: 100%;
  border-radius: inherit;
  background: #5b52bf;
}

.pill-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.pill {
  min-height: 56rpx;
  border-radius: 999rpx;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
}

.pill--purple {
  background: #e9e5ff;
  color: #534ab7;
}

.pill--mint {
  background: #dff3ee;
  color: #177968;
}

.pill--blue {
  background: #dcecff;
  color: #2f6bb0;
}

.pill--sky {
  background: #e8f2ff;
  color: #32679d;
}

.pill--gold {
  background: #f8ecd7;
  color: #89602a;
}

.profile-ikigai {
  display: block;
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: rgba(27, 27, 27, 0.82);
}
