<view class="profile-page">
  <view class="profile-header" style="{{headerStyle}}">
    <view class="profile-back" bindtap="handleBack">←</view>
    <view class="profile-header__center">
      <text class="profile-header__title">我的档案</text>
      <text class="profile-header__byline">{{profile.byline}}</text>
    </view>
  </view>

  <state-view
    visible="{{loading}}"
    type="loading"
    title="正在加载档案"
    desc="一树在整理你的资产画像"
    mode="inline"
  />

  <view wx:if="{{updateMode}}" class="update-banner">
    一树根据最近的对话为您提炼了新的资产特征，请查看并合并。
  </view>

  <scroll-view wx:if="{{!loading}}" class="profile-scroll" scroll-y>
    <state-view
      visible="{{error}}"
      type="error"
      title="档案同步失败"
      desc="当前没有回退本地数据，请检查接口后重试"
      actionText="重试"
      bind:action="handleRetry"
      mode="inline"
    />

    <state-view
      visible="{{!hasRealProfile && !loading}}"
      type="empty"
      title="档案还没开始积累"
      desc="先聊几轮，一树会自动生成你的资产雷达"
      mode="inline"
    />

    <view class="profile-user">
      <view class="profile-avatar-wrap {{avatarUploading ? 'profile-avatar-wrap--uploading' : ''}}" bindtap="handleAvatarTap">
        <image
          wx:if="{{profile.avatarUrl && !profileAvatarLoadFailed}}"
          class="profile-avatar profile-avatar--image"
          src="{{profile.avatarUrl}}"
          mode="aspectFill"
          binderror="handleProfileAvatarError"
        />
        <image
          wx:else
          class="profile-avatar"
          src="/assets/images/default-avatar-atree.svg"
          mode="aspectFit"
        />
        <view wx:if="{{runtime.loggedIn && avatarUploading}}" class="profile-avatar-badge">上传中</view>
      </view>
      <text class="profile-name">{{profile.name}}</text>
      <text class="profile-stage">{{profile.stageLabel}}</text>
      <text wx:if="{{runtime.loggedIn}}" class="profile-avatar-hint">点击头像修改</text>
    </view>

    <view class="profile-card" wx:if="{{runtime.accountCardVisible}}">
      <text class="profile-card__title">{{runtime.debugInfoVisible ? '开发 / 账号面板' : '账号'}}</text>

      <view wx:if="{{runtime.debugInfoVisible}}" class="dev-grid">
        <view class="dev-cell">
          <text class="dev-cell__label">接口模式</text>
          <text class="dev-cell__value">{{runtime.modeLabel}}</text>
        </view>
        <view class="dev-cell">
          <text class="dev-cell__label">登录状态</text>
          <text class="dev-cell__value">{{runtime.authLabel}}</text>
        </view>
        <view class="dev-cell">
          <text class="dev-cell__label">登录方式</text>
          <text class="dev-cell__value">{{runtime.loginMode}}</text>
        </view>
        <view class="dev-cell">
          <text class="dev-cell__label">Token</text>
          <text class="dev-cell__value">{{runtime.hasToken ? '已存在' : '未写入'}}</text>
        </view>
      </view>

      <view wx:if="{{runtime.debugInfoVisible}}" class="dev-meta">
        <text class="dev-meta__text">用户：{{runtime.userName || '未命名用户'}} / {{runtime.userId || '无 ID'}}</text>
        <text class="dev-meta__text">Base URL：{{runtime.baseURL || '未配置'}}</text>
      </view>

      <text wx:if="{{accountError}}" class="dev-error">{{accountError}}</text>

      <view wx:if="{{runtime.loggedIn}}" class="dev-actions">
        <button class="dev-btn dev-btn--warn" bindtap="handleLogout" loading="{{accountBusy}}">
          退出登录
        </button>
      </view>
    </view>

    <view wx:if="{{profile.assetReport.hasReport}}" class="profile-card profile-card--report">
      <view class="profile-card__head">
        <text class="profile-card__title">{{profile.assetReport.isReview ? '资产复盘报告' : '资产盘点报告'}}</text>
        <text wx:if="{{profile.assetReport.reportVersion}}" class="profile-card__meta">v{{profile.assetReport.reportVersion}}</text>
      </view>
      <text wx:if="{{profile.assetReport.generatedAt}}" class="profile-card__byline">生成于 {{profile.assetReport.generatedAt}}</text>
      <block wx:if="{{profile.assetReport.sections.length}}">
        <view wx:for="{{profile.assetReport.sections}}" wx:key="title" wx:for-item="section" class="report-section">
          <text class="report-section__title">【{{section.title}}】</text>
          <view class="report-section__body">
            <text wx:for="{{section.lines}}" wx:key="*this" wx:for-item="line" class="report-section__line">{{line}}</text>
          </view>
        </view>
      </block>
      <text wx:else class="report-section__plain">{{profile.assetReport.finalReport}}</text>
    </view>

    <view class="profile-card">
      <text class="profile-card__title">资产雷达</text>
      <block wx:if="{{hasRealProfile}}">
        <block wx:for="{{profile.radar}}" wx:key="label">
          <view class="radar-row">
            <text class="radar-row__label">{{item.label}}</text>
            <view class="radar-row__track">
              <view class="radar-row__fill {{item.changed ? 'radar-row__fill--changed' : ''}}" style="width: {{item.value}}%;"></view>
            </view>
          </view>
        </block>
      </block>
      <text wx:else class="profile-card__empty">聊几轮后自动生成</text>
    </view>

    <view class="profile-card">
      <text class="profile-card__title">差异化优势</text>
      <view wx:if="{{profile.strengths.length}}" class="pill-row">
        <view wx:for="{{profile.strengths}}" wx:key="label" class="pill pill--purple {{item.isNew ? 'pill--new' : ''}}">{{item.label || item}}</view>
      </view>
      <text wx:else class="profile-card__empty">完成更多任务后解锁</text>
    </view>

    <view class="profile-card">
      <text class="profile-card__title">性格特质 (CliftonStrengths)</text>
      <view wx:if="{{hasRealProfile}}" class="pill-row">
        <view wx:for="{{profile.traits}}" wx:key="label" class="pill pill--{{item.tone}} {{item.isNew ? 'pill--new' : ''}}">{{item.label}}</view>
      </view>
      <text wx:else class="profile-card__empty">对话积累后自动识别</text>
    </view>

    <view class="profile-card profile-card--last">
      <text class="profile-card__title">Ikigai 交汇点</text>
      <text wx:if="{{hasRealProfile && profile.ikigai}}" class="profile-ikigai {{profile.ikigaiChanged ? 'text--changed' : ''}}">{{profile.ikigai}}</text>
      <text wx:else class="profile-card__empty">一树会在你推进一段时间后为你总结</text>
    </view>

    <view wx:if="{{updateMode}}" style="height: 180rpx;"></view>
  </scroll-view>

  <view wx:if="{{updateMode}}" class="profile-footer">
    <button class="action-btn action-btn--reject" bindtap="handleRejectUpdate">暂不更新</button>
    <button class="action-btn action-btn--accept" bindtap="handleAcceptUpdate">确认合并更新</button>
  </view>
</view>
