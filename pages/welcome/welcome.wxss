page {
  height: 100%;
  overflow: hidden;
  background: #f5f5f6;
}

.welcome {
  min-height: 100vh;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
  padding-left: 0;
  padding-right: 0;
  box-sizing: border-box;
  background: #f5f5f6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.welcome-frame {
  width: 100%;
  max-width: 750rpx;
  height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  background: #f5f5f6;
  box-sizing: border-box;
  overflow: visible;
  display: flex;
  justify-content: center;
}

.welcome-main {
  width: 100%;
  height: 100%;
  max-width: 660rpx;
  margin: 0 auto;
  padding: 0 56rpx 132rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  transform: translateY(72rpx);
}

.brand {
  display: block;
  color: #0d0d0d;
  line-height: 1.15;
  font-weight: 700;
}

.tagline {
  display: block;
  margin-top: 24rpx;
  color: #999999;
  line-height: 1.5;
  font-weight: 400;
}

.value-prop {
  display: block;
  margin-top: 72rpx;
  color: #0d0d0d;
  line-height: 1.4;
  white-space: pre-line;
  font-weight: 700;
}

.cta-group {
  margin-top: 120rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cta-btn {
  width: 100%;
  height: 120rpx;
  border-radius: 60rpx;
  border: none;
  background: #0d0d0d;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: background-color 0.2s ease;
  margin: 0;
  padding: 0;
  line-height: normal;
}

.cta-btn::after {
  border: none;
}

.cta-btn--hover {
  background: #333333;
}

.cta-btn:active {
  background: #111111;
}

.cta-btn--disabled {
  background: #dddddd;
  color: #999999;
}

.social-proof {
  display: block;
  width: 100%;
  max-width: 580rpx;
  margin-top: 32rpx;
  color: #bfbfbf;
  line-height: 1.5;
  font-weight: 400;
  text-align: center;
}
