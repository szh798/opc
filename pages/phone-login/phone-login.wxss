.phone-login-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 34rpx) 32rpx calc(env(safe-area-inset-bottom) + 36rpx);
  background: #f7f7f8;
  box-sizing: border-box;
}

.phone-login-card {
  padding: 34rpx 30rpx 30rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  box-shadow: 0 18rpx 44rpx rgba(17, 17, 17, 0.06);
}

.phone-login-title {
  display: block;
  color: #111111;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 600;
}

.phone-login-subtitle {
  display: block;
  margin-top: 12rpx;
  color: rgba(17, 17, 17, 0.56);
  font-size: 26rpx;
  line-height: 1.6;
}

.phone-login-form {
  margin-top: 34rpx;
}

.phone-login-field {
  width: 100%;
}

.phone-login-field + .phone-login-field {
  margin-top: 18rpx;
}

.phone-login-field--code {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.phone-login-input {
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #f7f7f8;
  border: 1rpx solid rgba(17, 17, 17, 0.1);
  color: #111111;
  font-size: 30rpx;
  line-height: 92rpx;
  box-sizing: border-box;
}

.phone-login-input--code {
  min-width: 0;
  flex: 1;
}

.phone-login-code-button {
  width: 190rpx;
  height: 92rpx;
  margin: 0;
  padding: 0 14rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
  color: #111111;
  font-size: 25rpx;
  line-height: 92rpx;
  font-weight: 500;
  white-space: nowrap;
}

.phone-login-code-button::after,
.phone-login-submit::after {
  border: none;
}

.phone-login-submit {
  width: 100%;
  height: 94rpx;
  margin-top: 28rpx;
  border-radius: 14rpx;
  background: #111111;
  color: #ffffff;
  font-size: 31rpx;
  line-height: 94rpx;
  font-weight: 500;
}

.phone-login-agreement {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 28rpx;
  color: rgba(17, 17, 17, 0.54);
  font-size: 24rpx;
  line-height: 1.6;
}

.phone-login-check {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(17, 17, 17, 0.28);
  background: #ffffff;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 30rpx;
  text-align: center;
  box-sizing: border-box;
}

.phone-login-check--active {
  border-color: #111111;
  background: #111111;
}

.phone-login-agreement__text {
  color: rgba(17, 17, 17, 0.54);
}

.phone-login-link {
  color: #1f67c8;
}
