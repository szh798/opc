.legal-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 24rpx) 24rpx calc(env(safe-area-inset-bottom) + 32rpx);
  background: #f7f7f8;
}

.legal-head__title {
  display: block;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #111111;
}

.legal-head__meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(17, 17, 17, 0.52);
}

.legal-card {
  margin-top: 22rpx;
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(20, 20, 20, 0.06);
}

.legal-section + .legal-section {
  margin-top: 28rpx;
}

.legal-section__title {
  display: block;
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #161616;
}

.legal-section__paragraph {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: rgba(17, 17, 17, 0.82);
  white-space: pre-wrap;
}
