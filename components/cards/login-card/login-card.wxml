<view class="card {{mode === 'done' ? 'card--done' : ''}}">
  <view wx:if="{{mode === 'done'}}" class="card-done">
    <image
      wx:if="{{displayAvatarUrl && !avatarLoadFailed}}"
      class="card-done__avatar card-done__avatar--image"
      src="{{displayAvatarUrl}}"
      mode="aspectFit"
      binderror="handleAvatarError"
    />
    <image
      wx:else
      class="card-done__avatar"
      src="/assets/images/default-avatar-atree.svg"
      mode="aspectFit"
    />
    <view class="card-done__content">
      <text class="card-done__name">{{userName}}</text>
      <text class="card-done__status">已通过微信登录</text>
    </view>
    <view class="card-done__badge">已登录</view>
  </view>

  <button
    wx:else
    id="login-primary-button"
    class="card__button"
    loading="{{profileRequestPending}}"
    disabled="{{profileRequestPending || phoneLoginPending || smsLoginPending}}"
    bindtap="handleTap"
  >
    {{buttonText}}
  </button>

  <button
    wx:if="{{mode !== 'done' && showPhoneNumberLogin}}"
    id="login-phone-number-button"
    class="card__button card__button--secondary"
    open-type="getPhoneNumber"
    loading="{{phoneLoginPending}}"
    disabled="{{profileRequestPending || phoneLoginPending || smsLoginPending}}"
    bindgetphonenumber="handlePhoneNumberLogin"
  >
    手机号一键登录
  </button>

  <button
    wx:if="{{mode !== 'done' && showSmsLogin}}"
    id="login-sms-toggle-button"
    class="card__button card__button--secondary"
    disabled="{{profileRequestPending || phoneLoginPending || smsLoginPending}}"
    bindtap="toggleSmsPanel"
  >
    手机验证码登录
  </button>

  <button
    wx:if="{{mode !== 'done' && showDevFreshButton}}"
    id="login-dev-fresh-button"
    class="card__button card__button--secondary"
    disabled="{{profileRequestPending || phoneLoginPending || smsLoginPending}}"
    bindtap="handleDevFreshTap"
  >
    {{devFreshButtonText || '模拟新用户登录'}}
  </button>

  <button
    wx:if="{{mode !== 'done' && showDevOpportunityHubButton}}"
    id="login-dev-opportunity-hub-button"
    class="card__button card__button--secondary"
    disabled="{{profileRequestPending || phoneLoginPending || smsLoginPending}}"
    bindtap="handleDevOpportunityHubTap"
  >
    {{devOpportunityHubButtonText || '一键进入 Opportunity Hub'}}
  </button>

  <view wx:if="{{mode !== 'done'}}" class="card__agreement">
    <text>登录即代表同意</text>
    <text class="card__link" data-type="terms" catchtap="handleAgreementTap">《用户协议》</text>
    <text>与</text>
    <text class="card__link" data-type="privacy" catchtap="handleAgreementTap">《隐私政策》</text>
  </view>
</view>
