.card {
  width: 100%;
  padding: 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(17, 17, 17, 0.1);
  box-shadow: 0 12rpx 34rpx rgba(17, 17, 17, 0.06);
}

.card--done {
  border-color: rgba(16, 163, 127, 0.28);
  background: linear-gradient(180deg, #fbfffd, #f6fcfa);
}

.card__title {
  display: block;
  font-size: 32rpx;
  line-height: 1.28;
  font-weight: 500;
  color: #141414;
}

.card__desc {
  display: block;
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.65;
  color: rgba(26, 26, 26, 0.68);
}

.card__button {
  width: 100%;
  height: 90rpx;
  margin-top: 0;
  border-radius: 14rpx;
  background: #111111;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 90rpx;
  font-weight: 500;
}

.card__button::after {
  border: none;
}

.card__agreement {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: rgba(24, 24, 24, 0.5);
}

.card__link {
  color: #1f67c8;
}

.card-done {
  margin-top: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(16, 163, 127, 0.26);
  background: rgba(16, 163, 127, 0.08);
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
}

.card-done__avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #d9e8fb;
  color: #3b6eb5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.card-done__avatar--image {
  background: #d9e8fb;
}

.card-done__content {
  margin-left: 14rpx;
  min-width: 0;
  flex: 1;
}

.card-done__name {
  display: block;
  font-size: 30rpx;
  color: #16221d;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-done__status {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: rgba(22, 34, 29, 0.62);
}

.card-done__badge {
  margin-left: 10rpx;
  flex-shrink: 0;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  background: rgba(16, 163, 127, 0.16);
  color: #0f8a6d;
  font-size: 22rpx;
}
