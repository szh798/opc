.artifact-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.035);
  transform-origin: center;
  animation: artifact-card-enter 360ms ease-out both;
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.artifact-card--score {
  border-radius: 28rpx;
  border: 1rpx solid #eeeeef;
  box-shadow: 0 10rpx 32rpx rgba(13, 13, 13, 0.04);
}

.artifact-card--pressed {
  transform: scale(0.985);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.045);
}

.artifact-card__top,
.artifact-card__identity,
.artifact-card__actions,
.artifact-card__tags,
.artifact-card__metrics {
  display: flex;
  align-items: center;
}

.artifact-card__top {
  justify-content: space-between;
  gap: 18rpx;
}

.artifact-card__top--score {
  align-items: flex-start;
}

.artifact-card__identity {
  flex: 1;
  min-width: 0;
  gap: 18rpx;
}

.artifact-card__signal {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 1rpx solid currentColor;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  animation: artifact-signal-pulse 1800ms ease-out infinite;
}

.artifact-card__dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.artifact-card__heading {
  min-width: 0;
}

.artifact-card__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #0d0d0d;
}

.artifact-card__meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #737373;
}

.artifact-card__status {
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #534ab7;
  background: rgba(83, 74, 183, 0.1);
}

.artifact-card__status::after {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  left: -70%;
  width: 42%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0));
  transform: skewX(-18deg);
  animation: artifact-status-sweep 2200ms ease-in-out infinite;
}

.artifact-card__status--confirmed {
  color: #0f8f70;
  background: rgba(16, 163, 127, 0.1);
}

.artifact-card__status--draft {
  color: #b76b00;
  background: rgba(255, 173, 64, 0.14);
}

.artifact-card__status--running {
  color: #2f6fcc;
  background: rgba(55, 138, 221, 0.12);
}

.artifact-card__status--stale,
.artifact-card__status--failed {
  color: #c43d3b;
  background: rgba(226, 75, 74, 0.1);
}

.artifact-card__summary {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.48;
  color: #262626;
}

.artifact-card__summary--score {
  margin-top: 22rpx;
  font-size: 29rpx;
  line-height: 1.58;
  color: #262626;
}

.artifact-card__tags {
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.artifact-card__tags--score {
  margin-top: 20rpx;
}

.artifact-card__tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f1f2;
  color: #666666;
  font-size: 24rpx;
}

.artifact-card__score-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.artifact-card__score-cell {
  min-width: 0;
  min-height: 102rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e7e7ea;
  background: #fdfdfd;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.artifact-card__score-value {
  display: block;
  font-size: 32rpx;
  line-height: 1.2;
  color: #0d0d0d;
  font-weight: 500;
}

.artifact-card__score-label {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.2;
  color: #737373;
}

.artifact-card__metrics {
  gap: 10rpx;
  margin-top: 18rpx;
}

.artifact-card__metric {
  flex: 1;
  min-width: 0;
  padding: 10rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e8e8ea;
  background: #fbfbfc;
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 10rpx;
}

.artifact-card__metric-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #0d0d0d;
}

.artifact-card__metric-label {
  font-size: 22rpx;
  color: #737373;
}

.artifact-card__actions {
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 22rpx;
}

.artifact-card__actions--score {
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.artifact-card__action {
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e0e0e3;
  background: #ffffff;
  color: #404040;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  transition: transform 140ms ease, background 140ms ease, border-color 140ms ease;
}

.artifact-card__action--pressed {
  transform: scale(0.94);
  background: #f4f4f5;
}

.artifact-card__action--primary {
  background: #0d0d0d;
  border-color: #0d0d0d;
  color: #ffffff;
}

.artifact-card__action--confirm {
  background: #10a37f;
  border-color: #10a37f;
  color: #ffffff;
}

.artifact-card__action--primary.artifact-card__action--pressed {
  background: #242424;
}

.artifact-card__action--confirm.artifact-card__action--pressed {
  background: #0f8f70;
}

.artifact-card--running .artifact-card__signal,
.artifact-card--draft .artifact-card__signal {
  animation-duration: 1200ms;
}

@keyframes artifact-card-enter {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.985);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes artifact-signal-pulse {
  0% {
    box-shadow: 0 0 0 0 currentColor;
    opacity: 0.84;
  }
  70% {
    box-shadow: 0 0 0 14rpx rgba(255, 255, 255, 0);
    opacity: 1;
  }
  100% {
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
    opacity: 0.84;
  }
}

@keyframes artifact-status-sweep {
  0%,
  62% {
    left: -70%;
  }
  100% {
    left: 132%;
  }
}
