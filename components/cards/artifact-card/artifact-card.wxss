.card {
  width: 100%;
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--surface-primary, #ffffff);
  border: 1rpx solid var(--line-subtle, #e6e1d8);
  box-shadow: 0 12rpx 40rpx rgba(17, 17, 17, 0.04);
}

.card--soft {
  background: #fbfaf7;
}

.card__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 500;
  color: var(--text-primary, #121212);
}

.card__desc {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--text-secondary, #666666);
  white-space: pre-line;
}

.card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.card__tag {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #efebff;
  color: #534ab7;
  font-size: 24rpx;
}

.card__meta {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--text-tertiary, #8b857d);
}

.card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.card__button {
  flex: 1;
  min-height: 86rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.card__button--ghost {
  background: var(--surface-soft, #f2efe8);
  color: var(--text-primary, #121212);
  border: 1rpx solid var(--line-strong, #d0cac0);
}

.card__button--primary {
  background: var(--agent-color, #111111);
  color: #ffffff;
}
