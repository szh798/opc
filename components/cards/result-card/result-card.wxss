.result-card {
  padding: 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.08);
  background: #ffffff;
}

.result-card + .result-card {
  margin-top: 16rpx;
}

.result-card__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #181818;
}

.result-body {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-line {
  font-size: 30rpx;
  line-height: 1.65;
  color: rgba(22, 22, 22, 0.86);
}

.pricing-grid {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.pricing-item {
  flex: 1;
  border-radius: 16rpx;
  border: 1rpx solid rgba(20, 20, 20, 0.08);
  background: #f4f1ea;
  min-height: 116rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.pricing-item--active {
  border-color: rgba(16, 163, 127, 0.44);
  background: #dff4ec;
}

.pricing-item__label {
  font-size: 28rpx;
  color: rgba(25, 25, 25, 0.7);
}

.pricing-item__price {
  margin-top: 8rpx;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 500;
  color: #181818;
}

.score-list {
  margin-top: 16rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.score-row + .score-row {
  margin-top: 10rpx;
}

.score-row__label {
  width: 56rpx;
  font-size: 28rpx;
  color: rgba(24, 24, 24, 0.78);
}

.score-row__track {
  flex: 1;
  height: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #ebe8e0;
}

.score-row__fill {
  height: 100%;
  border-radius: inherit;
  background: #10a37f;
}

.score-row__fill--warn {
  background: #eba327;
}

.score-row__value {
  width: 48rpx;
  text-align: right;
  font-size: 28rpx;
  color: rgba(24, 24, 24, 0.74);
}

.score-summary {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 500;
  color: #10a37f;
}

.result-meta {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(24, 24, 24, 0.5);
}

.result-cta {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #2d63c8;
}
