.artifact-overview {
  padding: 32rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f4f1ff 100%);
  box-shadow: 0 18rpx 42rpx rgba(20, 20, 30, 0.06);
}

.artifact-overview__main,
.artifact-overview__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.artifact-overview__title {
  display: block;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #0d0d0d;
}

.artifact-overview__subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: #737373;
}

.artifact-overview__pill {
  flex-shrink: 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(83, 74, 183, 0.24);
  background: rgba(255, 255, 255, 0.74);
  color: #534ab7;
  font-size: 28rpx;
  font-weight: 700;
}

.artifact-overview__track {
  margin-top: 18rpx;
  height: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(13, 13, 13, 0.08);
}

.artifact-overview__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #534ab7, #10a37f);
}

.artifact-overview__bottom {
  margin-top: 28rpx;
}

.artifact-overview__hint {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  line-height: 1.45;
  color: #737373;
}

.artifact-overview__cta {
  flex-shrink: 0;
  min-width: 128rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #0d0d0d;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}
