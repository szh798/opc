.card {
  width: 100%;
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--surface-primary, #ffffff);
  border: 1rpx solid var(--line-subtle, #e6e1d8);
}

.card__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 500;
  color: var(--text-primary, #121212);
}

.task-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-item__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-checkbox {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  border: 2rpx solid var(--line-strong, #d0cac0);
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-checkbox--done {
  background: var(--accent, #10a37f);
  border-color: var(--accent, #10a37f);
}

.task-checkbox__check {
  font-size: 20rpx;
  line-height: 1;
  color: #ffffff;
}

.task-item__text {
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-primary, #121212);
}

.task-item__text--done {
  text-decoration: line-through;
  color: rgba(18, 18, 18, 0.42);
}

.task-item__tag {
  font-size: 24rpx;
  color: var(--text-tertiary, #8b857d);
}
