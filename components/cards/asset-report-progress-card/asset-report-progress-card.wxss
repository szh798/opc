.asset-progress-card {
  margin: 4rpx 0 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  border-radius: 48rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 45rpx rgba(15, 15, 15, 0.08);
  animation: assetProgressRise 0.42s ease both;
}

@keyframes assetProgressRise {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.asset-progress-card__top {
  padding: 34rpx 34rpx 28rpx;
  border-bottom: 1rpx solid #e8e8ea;
  background: linear-gradient(135deg, #ffffff 0%, #f5f3ff 100%);
}

.asset-progress-card__eyebrow {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
  color: #534ab7;
  font-size: 24rpx;
  font-weight: 600;
}

.asset-progress-card__pulse {
  position: relative;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #534ab7;
}

.asset-progress-card__pulse::after {
  position: absolute;
  inset: -10rpx;
  border: 2rpx solid rgba(83, 74, 183, 0.32);
  border-radius: 999rpx;
  content: "";
  animation: assetProgressPulse 1.6s ease-out infinite;
}

@keyframes assetProgressPulse {
  from {
    opacity: 1;
    transform: scale(0.65);
  }
  to {
    opacity: 0;
    transform: scale(1.7);
  }
}

.asset-progress-card--completed .asset-progress-card__pulse {
  background: #10a37f;
}

.asset-progress-card--failed .asset-progress-card__pulse {
  background: #d94f45;
}

.asset-progress-card__title {
  display: block;
  margin-bottom: 14rpx;
  color: #111111;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: -0.8rpx;
}

.asset-progress-card__subtitle {
  display: block;
  color: #737373;
  font-size: 26rpx;
  line-height: 1.55;
}

.asset-progress-card__insight {
  margin-top: 26rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(83, 74, 183, 0.14);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.74);
}

.asset-progress-card__insight-label {
  display: block;
  margin-bottom: 16rpx;
  color: #6a63b8;
  font-size: 24rpx;
  font-weight: 600;
}

.asset-progress-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.asset-progress-card__tag {
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 999rpx;
  background: #ffffff;
  color: #292929;
  font-size: 24rpx;
}

.asset-progress-card__body {
  padding: 30rpx 34rpx 34rpx;
}

.asset-progress-card__bar {
  height: 14rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ededf0;
}

.asset-progress-card__bar-fill {
  position: relative;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #534ab7, #10a37f);
  transition: width 0.7s ease;
}

.asset-progress-card__bar-fill::after {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.48), transparent);
  content: "";
  animation: assetProgressShimmer 1.5s infinite;
}

@keyframes assetProgressShimmer {
  from {
    transform: translateX(-100%);
  }
  to {
    transform: translateX(100%);
  }
}

.asset-progress-card__step {
  display: grid;
  grid-template-columns: 44rpx 1fr;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f1;
}

.asset-progress-card__step:last-child {
  border-bottom: 0;
}

.asset-progress-card__step-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  margin-top: 2rpx;
  border: 1rpx solid #dedee2;
  border-radius: 999rpx;
  background: #fafafa;
  color: #aaa;
  font-size: 22rpx;
}

.asset-progress-card__step-icon--done {
  border-color: transparent;
  background: #ecfdf6;
  color: #10a37f;
}

.asset-progress-card__step-icon--running {
  border-color: transparent;
  background: #f2f0ff;
  color: #534ab7;
}

.asset-progress-card__step-icon--running::after {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: currentColor;
  content: "";
  animation: assetProgressBlink 1s infinite alternate;
}

.asset-progress-card__step-icon--failed {
  border-color: transparent;
  background: #fff1ef;
  color: #d94f45;
}

@keyframes assetProgressBlink {
  from {
    opacity: 0.35;
  }
  to {
    opacity: 1;
  }
}

.asset-progress-card__step-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.asset-progress-card__step-title {
  color: #111111;
  font-size: 28rpx;
  font-weight: 650;
}

.asset-progress-card__step-status {
  flex: 0 0 auto;
  color: #9a9a9a;
  font-size: 22rpx;
}

.asset-progress-card__step-desc {
  display: block;
  margin-top: 8rpx;
  color: #737373;
  font-size: 24rpx;
  line-height: 1.45;
}

.asset-progress-card__radar {
  margin-top: 28rpx;
  padding: 26rpx;
  border: 1rpx solid #eeeeef;
  border-radius: 36rpx;
  background: #fafafa;
}

.asset-progress-card__radar-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  color: #111111;
  font-size: 26rpx;
  font-weight: 650;
}

.asset-progress-card__radar-head text:last-child {
  color: #737373;
  font-size: 24rpx;
  font-weight: 400;
}

.asset-progress-card__radar-list {
  display: grid;
  gap: 16rpx;
}

.asset-progress-card__radar-row {
  display: grid;
  grid-template-columns: 72rpx 1fr 44rpx;
  gap: 16rpx;
  align-items: center;
  color: #555555;
  font-size: 24rpx;
}

.asset-progress-card__radar-track {
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9e9eb;
}

.asset-progress-card__radar-fill {
  height: 100%;
  border-radius: inherit;
  background: #1f1f1f;
}
