.card {
  width: 100%;
  display: flex;
  border-radius: 20rpx;
  background: var(--surface-primary, #ffffff);
  border: 1rpx solid var(--line-subtle, #e6e1d8);
  overflow: hidden;
}

.card__content {
  flex: 1;
  padding: 22rpx 22rpx;
}

.card__paragraph {
  display: block;
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--text-primary, #121212);
}

.card__paragraph--lead {
  font-size: 36rpx;
  line-height: 1.45;
  font-weight: 500;
}

.card__paragraph + .card__paragraph {
  margin-top: 14rpx;
}

.card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.card__button {
  flex: 1;
  min-height: 88rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--line-strong, #d0cac0);
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--text-primary, #121212);
  font-weight: 500;
}

.card__button--primary {
  background: #ffffff;
}
