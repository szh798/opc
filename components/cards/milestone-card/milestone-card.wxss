.card {
  width: 100%;
  padding: 34rpx 30rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background:
    radial-gradient(120% 120% at 10% 0%, rgba(47, 47, 47, 0.85), rgba(17, 17, 17, 0.88) 48%, rgba(12, 12, 12, 0.96)),
    #101010;
  color: #ffffff;
  box-shadow: 0 22rpx 48rpx rgba(8, 8, 8, 0.28);
}

.card__check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  font-size: 46rpx;
  line-height: 1;
}

.card__check--success {
  background: #10a37f;
}

.card__title,
.card__unlocked,
.card__copy {
  display: block;
  text-align: center;
}

.card__title {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.card__unlocked {
  margin-top: 10rpx;
  font-size: 36rpx;
  line-height: 1.3;
  color: #10c39a;
  font-weight: 500;
}

.card__copy {
  margin-top: 24rpx;
  font-size: 30rpx;
  line-height: 1.72;
  color: rgba(255, 255, 255, 0.76);
}

.card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 34rpx;
}

.card__button {
  flex: 1;
  min-height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 500;
}

.card__button--ghost {
  background: linear-gradient(180deg, rgba(58, 58, 58, 0.8), rgba(32, 32, 32, 0.9));
  color: #f6f6f6;
}

.card__button--primary {
  background: linear-gradient(180deg, #13b48d, #10a37f);
  color: #ffffff;
}
