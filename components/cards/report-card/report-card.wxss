.card {
  width: 100%;
  padding: 28rpx;
  border-radius: 22rpx;
  background: var(--surface-primary, #ffffff);
  border: 1rpx solid var(--line-subtle, #e6e1d8);
  box-shadow: 0 6rpx 20rpx rgba(16, 16, 16, 0.03);
}

.card__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 500;
  color: var(--text-primary, #121212);
}

.weekly-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.weekly-cell {
  width: calc(50% - 8rpx);
  min-height: 148rpx;
  padding: 22rpx;
  border-radius: 14rpx;
  background: #f4f2ec;
}

.weekly-cell__label {
  display: block;
  font-size: 24rpx;
  line-height: 1.3;
  color: var(--text-secondary, #666666);
}

.weekly-cell__value-row {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
  margin-top: 14rpx;
}

.weekly-cell__value {
  display: block;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 500;
  color: #1d1d1d;
}

.weekly-cell__value--positive {
  color: #10a37f;
}

.weekly-cell__value--asset {
  color: #534ab7;
}

.weekly-cell__extra {
  font-size: 28rpx;
  line-height: 1;
  color: #10a37f;
  font-weight: 500;
}

.metric-list {
  margin-top: 18rpx;
}

.metric-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  border-bottom: 1rpx solid #efede8;
}

.metric-row:last-child {
  border-bottom: none;
}

.metric-row__label {
  font-size: 28rpx;
  color: #333333;
}

.metric-row__value {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.metric-row__main {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary, #121212);
}

.metric-row__accent {
  font-size: 32rpx;
  font-weight: 500;
}

.metric-row__main--positive,
.metric-row__accent--positive {
  color: #10a37f;
}

.metric-row__main--warn,
.metric-row__accent--warn {
  color: #d17f09;
}

.card__copy {
  display: block;
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: #2e2e2e;
}

.card__footer {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #efede8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card__action {
  font-size: 28rpx;
  color: #2d63c8;
  white-space: nowrap;
}

.card__meta {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-tertiary, #8b857d);
}
