.policy-card {
  width: 100%;
  padding: 28rpx;
  border-radius: 30rpx;
  background: #f7f4ed;
  border: 1rpx solid #dfd7c8;
  box-shadow: 0 14rpx 42rpx rgba(30, 26, 19, 0.06);
}

.policy-card__eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 0.08em;
  color: #8c7d62;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.policy-card__title {
  display: block;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 600;
  color: #17140f;
}

.policy-card__desc {
  display: block;
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #625b50;
}

.policy-card__meta {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #8c7d62;
}

.policy-card__items {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.policy-card__item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(196, 181, 153, 0.55);
}

.policy-card__item-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.policy-card__item-title {
  flex: 1;
  font-size: 29rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #17140f;
}

.policy-card__score {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 22rpx;
}

.policy-card__source,
.policy-card__line,
.policy-card__disclaimer {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.65;
  color: #5f594f;
}

.policy-card__source {
  color: #8c6f2d;
}

.policy-card__risks {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 14rpx;
}

.policy-card__risk {
  font-size: 23rpx;
  line-height: 1.5;
  color: #8a4b1f;
}

.policy-card__mini-actions,
.policy-card__actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.policy-card__mini,
.policy-card__button {
  flex: 1;
  min-height: 74rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
}

.policy-card__mini {
  background: #ede6d7;
  color: #211d17;
}

.policy-card__button--ghost {
  background: #ece6da;
  color: #17140f;
}

.policy-card__button--primary {
  background: #111111;
  color: #ffffff;
}
