<view class="header">
  <view class="header__side header__side--left" bindtap="handleAvatarTap">
    <view class="header__avatar">{{userInitial}}</view>
    <view wx:if="{{showMenu}}" class="header__menu">
      <view class="header__menu-line"></view>
      <view class="header__menu-line"></view>
      <view class="header__menu-line"></view>
    </view>
  </view>

  <view class="header__center">
    <view class="header__dot" style="background: {{agentMeta.color}};"></view>
    <text class="header__label" style="color: {{agentMeta.color}};">{{agentMeta.label}}</text>
  </view>

  <view wx:if="{{showTree}}" class="header__side header__side--right" bindtap="handleTreeTap">
    <view class="tree-icon">
      <view class="tree-icon__branch tree-icon__branch--left"></view>
      <view class="tree-icon__branch tree-icon__branch--right"></view>
      <view class="tree-icon__branch tree-icon__branch--top"></view>
      <view class="tree-icon__trunk"></view>
    </view>
  </view>
</view>
