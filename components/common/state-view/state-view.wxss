.state {
  margin: 20rpx 0;
  padding: 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.1);
  background: rgba(255, 255, 255, 0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.state--inline {
  margin: 0;
}

.state__spinner {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.18);
  border-top-color: #111111;
  animation: spin 0.9s linear infinite;
}

.state__title {
  margin-top: 12rpx;
  font-size: 30rpx;
  line-height: 1.4;
  color: #121212;
  font-weight: 500;
}

.state__desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: rgba(18, 18, 18, 0.62);
}

.state__action {
  margin-top: 14rpx;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.16);
  background: #ffffff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #121212;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
