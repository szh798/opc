.artifact-sheet {
  position: fixed;
  inset: 0;
  z-index: 120;
}

.artifact-sheet__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.34);
}

.artifact-sheet__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 78vh;
  box-sizing: border-box;
  padding: 24rpx 46rpx calc(env(safe-area-inset-bottom) + 34rpx);
  border-radius: 42rpx 42rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 60rpx rgba(0, 0, 0, 0.1);
  overflow-y: auto;
}

.artifact-sheet__handle {
  width: 74rpx;
  height: 9rpx;
  margin: 0 auto 34rpx;
  border-radius: 999rpx;
  background: #d7d7dc;
}

.artifact-sheet__header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #e8e8ea;
}

.artifact-sheet__title {
  display: block;
  font-size: 40rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #0d0d0d;
}

.artifact-sheet__meta {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  color: #737373;
}

.artifact-sheet__close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #f3f3f4;
  color: #3d3d3d;
  font-size: 46rpx;
  line-height: 54rpx;
  text-align: center;
  flex-shrink: 0;
}

.artifact-sheet__section {
  padding: 26rpx 0;
  border-bottom: 1rpx solid #eeeeef;
}

.artifact-sheet__label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: #737373;
}

.artifact-sheet__body,
.artifact-sheet__bullet {
  display: block;
  font-size: 31rpx;
  line-height: 1.65;
  color: #202020;
}

.artifact-sheet__bullets {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.artifact-sheet__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 24rpx 0 12rpx;
}

.artifact-sheet__tag {
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f3f4;
  font-size: 24rpx;
  color: #555555;
}

.artifact-sheet__actions {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.artifact-sheet__button {
  min-width: 148rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dedee3;
  background: #ffffff;
  color: #0d0d0d;
  font-size: 28rpx;
  line-height: 68rpx;
  text-align: center;
}

.artifact-sheet__button--primary {
  border-color: #0d0d0d;
  background: #0d0d0d;
  color: #ffffff;
}
