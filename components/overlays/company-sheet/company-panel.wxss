.sheet-layer {
  position: fixed;
  inset: 0;
  z-index: 29;
  pointer-events: none;
}

.sheet-layer--show {
  pointer-events: auto;
}

.sheet-layer__mask {
  position: absolute;
  inset: 0;
  background: rgba(17, 17, 17, 0);
  transition: background 0.24s ease;
}

.sheet-layer--show .sheet-layer__mask {
  background: rgba(17, 17, 17, 0.18);
}

.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 24rpx calc(env(safe-area-inset-bottom) + 18rpx);
  border-radius: 32rpx 32rpx 0 0;
  background: var(--surface-primary, #ffffff);
  transform: translateY(100%);
  transition: transform 0.24s ease;
  max-height: 68vh;
  box-shadow: 0 -10rpx 40rpx rgba(16, 16, 16, 0.16);
}

.sheet-layer--show .sheet {
  transform: translateY(0);
}

.sheet__grab {
  width: 84rpx;
  height: 8rpx;
  border-radius: 999rpx;
  margin: 8rpx auto 14rpx;
  background: rgba(17, 17, 17, 0.16);
}

.sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx 16rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.08);
}

.sheet__title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #181818;
}

.sheet__close {
  width: 54rpx;
  text-align: center;
  font-size: 52rpx;
  line-height: 1;
  color: rgba(25, 25, 25, 0.56);
}

.company-sheet__body {
  height: calc(68vh - 102rpx - env(safe-area-inset-bottom));
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-right: 4rpx;
}

.company-card {
  padding: 24rpx;
  border-radius: 22rpx;
  background: var(--surface-soft, #f2efe8);
}

.company-card__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.company-card__row + .company-card__row {
  margin-top: 14rpx;
}

.company-card__row--top {
  margin-bottom: 16rpx;
}

.company-card__title-wrap {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.company-card__icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #378add;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
}

.company-card__title {
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 500;
  color: var(--text-primary, #121212);
}

.company-card__badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ddf3ec;
  color: var(--accent, #10a37f);
  font-size: 22rpx;
}

.company-card__label,
.company-card__value {
  font-size: 28rpx;
  line-height: 1.5;
}

.company-card__label {
  color: var(--text-secondary, #666666);
}

.company-card__value {
  color: var(--text-primary, #121212);
}

.company-card__value--danger {
  color: #be3535;
}

.company-progress {
  margin-top: 14rpx;
}

.company-progress__bars {
  display: flex;
  gap: 8rpx;
}

.company-progress__bar {
  height: 16rpx;
  border-radius: 99rpx;
}

.company-progress__labels {
  margin-top: 8rpx;
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.company-progress__label {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: rgba(25, 25, 25, 0.54);
}

.company-card__action {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #2d63c8;
}
