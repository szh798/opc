.sheet-layer {
  position: fixed;
  inset: 0;
  z-index: 36;
  pointer-events: none;
}

.sheet-layer--show {
  pointer-events: auto;
}

.sheet-layer__mask {
  position: absolute;
  inset: 0;
  background: rgba(10, 10, 12, 0);
  transition: background 0.26s ease;
}

.sheet-layer--show .sheet-layer__mask {
  background: rgba(10, 10, 12, 0.32);
}

.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  padding: 12rpx 24rpx calc(env(safe-area-inset-bottom) + 22rpx);
  box-shadow: 0 -12rpx 42rpx rgba(12, 12, 12, 0.16);
  transform: translateY(100%);
  transition: transform 0.26s ease;
  max-height: 62vh;
  overflow: hidden;
}

.sheet-layer--show .sheet {
  transform: translateY(0);
}

.sheet__grab {
  width: 80rpx;
  height: 8rpx;
  border-radius: 99rpx;
  margin: 6rpx auto 14rpx;
  background: rgba(18, 18, 18, 0.16);
}

.sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 6rpx 18rpx;
}

.sheet__title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #121212;
}

.sheet__close {
  font-size: 48rpx;
  line-height: 1;
  color: rgba(24, 24, 24, 0.6);
}

.sheet__body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: calc(62vh - 120rpx - env(safe-area-inset-bottom));
  overflow: auto;
}

.project-card {
  min-height: 114rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f4f2ec;
  border: 1rpx solid rgba(18, 18, 18, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.project-card__left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.project-card__dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 99rpx;
  flex-shrink: 0;
}

.project-card__name {
  display: block;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 500;
  color: #1a1a1a;
}

.project-card__phase {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: rgba(18, 18, 18, 0.56);
}

.project-card__status {
  margin-left: 12rpx;
  flex-shrink: 0;
  font-size: 30rpx;
  color: rgba(28, 28, 28, 0.65);
}

.project-card__status--alert {
  min-width: 90rpx;
  height: 52rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #f8eaee;
  color: #b75062;
  font-size: 26rpx;
  font-weight: 500;
}

.project-card--ghost {
  justify-content: center;
  border-style: dashed;
  border-color: rgba(17, 17, 17, 0.18);
  background: #fbfbfb;
  color: rgba(25, 25, 25, 0.74);
  font-size: 30rpx;
}
