.sheet-layer {
  position: fixed;
  inset: 0;
  z-index: 28;
  pointer-events: none;
}

.sheet-layer--show {
  pointer-events: auto;
}

.sheet-layer__mask {
  position: absolute;
  inset: 0;
  background: rgba(17, 17, 17, 0);
  transition: background 0.24s ease;
}

.sheet-layer--show .sheet-layer__mask {
  background: rgba(17, 17, 17, 0.18);
}

.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 22rpx 24rpx calc(env(safe-area-inset-bottom) + 22rpx);
  border-radius: 36rpx 36rpx 0 0;
  background: var(--surface-primary, #ffffff);
  transform: translateY(100%);
  transition: transform 0.24s ease;
}

.sheet-layer--show .sheet {
  transform: translateY(0);
}

.sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 18rpx;
}

.sheet__title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 500;
  color: var(--text-primary, #121212);
}

.sheet__close {
  font-size: 48rpx;
  line-height: 1;
  color: var(--text-secondary, #666666);
}

.sheet__body {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.project-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 124rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: var(--surface-soft, #f2efe8);
}

.project-card__left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.project-card__dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.project-card__name {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 500;
  color: var(--text-primary, #121212);
}

.project-card__phase {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-secondary, #666666);
}

.project-card__status {
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
}

.project-card--ghost {
  justify-content: center;
  border: 1rpx dashed var(--line-strong, #d0cac0);
  background: #ffffff;
  font-size: 32rpx;
  color: var(--text-secondary, #666666);
}
