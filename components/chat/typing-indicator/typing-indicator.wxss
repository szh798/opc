.typing-card {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: var(--surface-primary, #ffffff);
  border: 1rpx solid var(--line-subtle, #e6e1d8);
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #a9a39b;
  animation: typing-pulse 1s ease-in-out infinite;
}

.typing-dot--2 {
  animation-delay: 0.12s;
}

.typing-dot--3 {
  animation-delay: 0.24s;
}

@keyframes typing-pulse {
  0%,
  80%,
  100% {
    opacity: 0.35;
    transform: translateY(0);
  }

  40% {
    opacity: 1;
    transform: translateY(-4rpx);
  }
}
