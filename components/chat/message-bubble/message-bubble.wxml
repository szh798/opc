<view
  class="message-bubble message-bubble--{{variant}} {{singleLine ? 'message-bubble--single' : ''}} {{compact ? 'message-bubble--compact' : ''}}"
  style="{{variant === 'agent' && borderColor ? 'border-color:' + borderColor + ';' : ''}}"
>
  <text class="message-bubble__text {{singleLine ? 'message-bubble__text--single' : ''}} {{compact ? 'message-bubble__text--compact' : ''}}">{{text}}</text>
  <view wx:if="{{compact}}" class="message-bubble__dots" aria-hidden="true">
    <view class="message-bubble__dot"></view>
    <view class="message-bubble__dot"></view>
    <view class="message-bubble__dot"></view>
  </view>
  <view
    wx:if="{{variant === 'agent' && !compact && !singleLine && text}}"
    class="message-bubble__aigc-tag"
    aria-label="内容由 AI 生成"
  >AI 生成</view>
</view>
