<view class="sidebar-layer {{visible ? 'sidebar-layer--show' : ''}}">
  <view class="sidebar-layer__mask" catchtap="handleMaskTap"></view>

  <view class="sidebar-panel" style="{{panelStyle}}">
    <view class="sidebar-user" bindtap="handleProfileTap">
      <image
        wx:if="{{displayUser.avatarUrl && !avatarLoadFailed}}"
        class="sidebar-user__avatar sidebar-user__avatar--image"
        src="{{displayUser.avatarUrl}}"
        mode="aspectFill"
        binderror="handleAvatarError"
      />
      <image
        wx:else
        class="sidebar-user__avatar"
        src="/assets/images/default-avatar-atree.svg"
        mode="aspectFit"
      />
      <view class="sidebar-user__content">
        <text class="sidebar-user__name">{{displayUser.name}}</text>
        <text class="sidebar-user__desc">{{displayUser.subtitle}}</text>
      </view>
    </view>

    <button class="sidebar-new-chat" bindtap="handleNewChatTap">+ 新对话</button>

    <view class="sidebar-section">
      <text class="sidebar-section__label">PROJECTS</text>
      <block wx:for="{{projects}}" wx:key="id">
        <view class="sidebar-item" data-id="{{item.id}}" bindtap="handleProjectTap">
          <view class="sidebar-item__left">
            <view class="sidebar-item__dot" style="background: {{item.color}};"></view>
            <view class="sidebar-item__content">
              <text class="sidebar-item__name">{{item.name}}</text>
              <text class="sidebar-item__phase">{{item.phase}}</text>
            </view>
          </view>
          <text class="sidebar-item__meta {{item.statusTone === 'alert' ? 'sidebar-item__meta--alert' : ''}}">{{item.status}}</text>
        </view>
      </block>
    </view>

    <view class="sidebar-section">
      <text class="sidebar-section__label">TOOLS</text>
      <view class="sidebar-tools">
        <block wx:for="{{tools}}" wx:key="key">
          <view
            class="sidebar-tool {{activeToolKey === item.key ? 'sidebar-tool--active' : ''}}"
            data-key="{{item.key}}"
            bindtap="handleToolTap"
          >
            {{item.label}}
          </view>
        </block>
      </view>
    </view>

    <view class="sidebar-section sidebar-section--grow">
      <text class="sidebar-section__label">RECENT CHATS</text>
      <scroll-view class="sidebar-chats" scroll-y>
        <view wx:if="{{!renderRecentChats.length}}" class="sidebar-empty">还没有最近聊天</view>
        <block wx:for="{{renderRecentChats}}" wx:key="id">
          <view class="sidebar-chat-swipe">
            <view class="sidebar-chat__actions">
              <view class="sidebar-chat__delete" data-id="{{item.id}}" catchtap="handleRecentDelete">删除</view>
            </view>
            <view
              class="sidebar-chat"
              data-id="{{item.id}}"
              bindtap="handleRecentTap"
              catchtouchstart="handleRecentTouchStart"
              catchtouchmove="handleRecentTouchMove"
              catchtouchend="handleRecentTouchEnd"
              catchtouchcancel="handleRecentTouchCancel"
              style="transform: translateX({{item.offsetX}}px);"
            >
              {{item.label}}
            </view>
          </view>
        </block>
      </scroll-view>
    </view>

    <view class="sidebar-footer">
      <text class="sidebar-footer__link" bindtap="handleSettingTap">设置</text>
      <text class="sidebar-footer__link" bindtap="handleHelpTap">帮助</text>
    </view>
  </view>
</view>
