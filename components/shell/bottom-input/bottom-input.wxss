.composer {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  padding: 10rpx 14rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.14);
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(15, 15, 18, 0.06);
}

.composer--skills {
  align-items: stretch;
  flex-direction: column;
  gap: 8rpx;
  padding: 12rpx 14rpx 10rpx;
  border-radius: 34rpx;
}

.composer__input-row {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}

.composer__tool-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  min-height: 68rpx;
}

.composer__tool-left {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.composer__plus,
.composer__send {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 4rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 500;
}

.composer__plus {
  border: 1rpx solid rgba(17, 17, 17, 0.2);
  color: #2a2a2a;
  background: #ffffff;
}

.composer--skills .composer__plus {
  margin-bottom: 0;
  border-color: transparent;
  background: transparent;
  color: #2a2a2a;
}

.composer__skill-entry {
  position: relative;
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0efe9;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  transition: background 0.18s ease, border-color 0.18s ease;
}

.composer__skill-entry--active {
  background: #e8e6df;
  border-color: rgba(17, 17, 17, 0.14);
}

.composer__skill-entry--active::before {
  content: "Skills";
  position: absolute;
  left: 50%;
  bottom: calc(100% + 14rpx);
  transform: translateX(-50%);
  padding: 12rpx 18rpx;
  border-radius: 16rpx;
  background: #111111;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
  white-space: nowrap;
  box-shadow: 0 10rpx 28rpx rgba(17, 17, 17, 0.2);
}

.composer__skill-book {
  position: relative;
  width: 34rpx;
  height: 30rpx;
  display: flex;
}

.composer__skill-book::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 4rpx;
  bottom: 4rpx;
  width: 2rpx;
  transform: translateX(-50%);
  background: #2a2a2a;
  border-radius: 999rpx;
}

.composer__skill-book-page {
  width: 17rpx;
  height: 30rpx;
  border: 3rpx solid #2a2a2a;
  box-sizing: border-box;
  background: transparent;
}

.composer__skill-book-page--left {
  border-radius: 7rpx 2rpx 2rpx 7rpx;
  border-right-width: 1rpx;
}

.composer__skill-book-page--right {
  border-radius: 2rpx 7rpx 7rpx 2rpx;
  border-left-width: 1rpx;
}

.composer__send {
  border: 1rpx solid rgba(17, 17, 17, 0.12);
  background: #efeee9;
  color: rgba(31, 31, 31, 0.44);
  transition: all 0.18s ease;
}

.composer--skills .composer__send {
  margin-bottom: 0;
}

.composer__send--active {
  background: #111111;
  color: #ffffff;
  border-color: #111111;
}

/* 停止键:流式输出期间替换发送箭头。复用 composer__send 的尺寸 + 边框,
   内部放一个小黑方块指示"停止"。 */
.composer__send--stop {
  background: #111111;
  border-color: #111111;
}

.composer__stop-square {
  width: 22rpx;
  height: 22rpx;
  border-radius: 4rpx;
  background: #ffffff;
}

.composer__input {
  flex: 1;
  min-width: 0;
  min-height: 70rpx;
  max-height: 260rpx;
  padding: 14rpx 22rpx;
  border-radius: 28rpx;
  background: #f0efe9;
  color: #151515;
  font-size: 30rpx;
  line-height: 42rpx;
  box-sizing: border-box;
  overflow-y: auto;
  word-break: break-all;
  white-space: pre-wrap;
}

.composer--skills .composer__input {
  width: 100%;
  min-height: 58rpx;
  padding: 8rpx 8rpx 2rpx;
  border-radius: 0;
  background: transparent;
}

.composer__skill-chip {
  max-width: 80%;
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f4f4f2;
  color: #1f1f1f;
  box-sizing: border-box;
}

.composer__skill-chip-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.composer__skill-chip-icon-square {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid #4f6fff;
  border-radius: 5rpx;
  box-sizing: border-box;
  background: transparent;
}

.composer__skill-chip-icon-square--front {
  left: 1rpx;
  top: 1rpx;
}

.composer__skill-chip-icon-square--back {
  right: 1rpx;
  bottom: 1rpx;
}

.composer__skill-chip-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 500;
}

.composer__placeholder {
  color: rgba(30, 30, 30, 0.42);
}
